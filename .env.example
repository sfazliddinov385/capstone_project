# =============================================================================
# Travlr Getaways environment configuration
# Copy this file to .env and fill in the values. NEVER commit .env to git.
# =============================================================================

# --- Required ---------------------------------------------------------------

# Where MongoDB lives. Local dev default works with a stock mongod on 27017.
MONGODB_URI=mongodb://localhost:27017/travlr

# Secret used to sign and verify JWTs. MUST be set, MUST be long and random.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server refuses to start if this is missing or shorter than 32 characters.
JWT_SECRET=replace-me-with-at-least-32-random-bytes-of-entropy

# --- Optional ---------------------------------------------------------------

# Port the Express server listens on. Defaults to 3000.
PORT=3000

# Comma-separated list of origins allowed to call /api. The Angular admin runs
# on http://localhost:4200 in development. In production, set this to the
# public origin(s) of your admin UI. Use "*" to disable the allowlist (NOT
# recommended in production).
CORS_ORIGIN=http://localhost:4200

# Gmail credentials for the reservation-confirmation email. If either is
# missing, the email is skipped silently (no PII is logged) so the app remains
# runnable without SMTP.
# For Gmail use an App Password, not your real account password.
EMAIL_USER=
EMAIL_PASS=

# Public origin of the customer site, used inside outbound emails so links
# point at the real domain instead of localhost. Defaults to http://localhost:PORT.
PUBLIC_URL=

# bcrypt work factor. 12 is the modern default; raise for higher security at
# the cost of slower login.
BCRYPT_ROUNDS=12

# Set to "production" to enable trust-proxy + tighter helmet defaults.
NODE_ENV=development

# --- Optional: operational scripts ------------------------------------------

# Read by scripts/create-admin.js to seed an admin user. If unset, defaults
# below are used. Override BEFORE running the script in a shared environment.
ADMIN_EMAIL=admin@travlr.com
ADMIN_PASSWORD=password123
ADMIN_NAME=Admin

# Comma-separated email addresses to KEEP when scripts/reset-customers.js
# wipes test accounts. Defaults to sfazliddinov385@gmail.com.
PRESERVE_EMAILS=sfazliddinov385@gmail.com
