{{> header}}

<section class="tg-auth-page">

    <!-- ── LEFT: brand panel (benefits flavor) ──────────────── -->
    <aside class="tg-auth-brand" aria-hidden="true">
        <div class="tg-auth-brand-bg">
            <div class="tg-travel-blob tg-travel-blob-1"></div>
            <div class="tg-travel-blob tg-travel-blob-2"></div>
            <div class="tg-travel-blob tg-travel-blob-3"></div>
            <div class="tg-travel-grid-overlay"></div>
        </div>

        <div class="tg-auth-brand-inner">
            <a href="/" class="tg-auth-brand-logo">
                <span class="tg-auth-brand-mark">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                Travlr <span>Getaways</span>
            </a>

            <div class="tg-auth-brand-content">
                <div class="tg-travel-hero-eyebrow">
                    <span class="tg-eyebrow-dot"></span>
                    Join the journey
                </div>
                <h2 class="tg-auth-brand-title">
                    Start your <em data-shimmer>travel story</em> with us
                </h2>
                <p class="tg-auth-brand-sub">
                    Create a free account in seconds and unlock the full Travlr experience.
                </p>

                <!-- Benefits list (replaces the testimonial on this page) -->
                <ul class="tg-auth-benefits">
                    <li>
                        <span class="tg-auth-benefit-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </span>
                        <div>
                            <strong>Manage every booking</strong>
                            <span>Track trips, cancel reservations, and download invoices anytime.</span>
                        </div>
                    </li>
                    <li>
                        <span class="tg-auth-benefit-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                        </span>
                        <div>
                            <strong>Save favorites</strong>
                            <span>Build a shortlist of destinations to revisit when you're ready to book.</span>
                        </div>
                    </li>
                    <li>
                        <span class="tg-auth-benefit-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        </span>
                        <div>
                            <strong>Member-only deals</strong>
                            <span>Get early access to flash sales and seasonal getaway packages.</span>
                        </div>
                    </li>
                    <li>
                        <span class="tg-auth-benefit-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
                        </span>
                        <div>
                            <strong>Leave reviews</strong>
                            <span>Share your trip experience and help other travelers plan their next escape.</span>
                        </div>
                    </li>
                </ul>

                <div class="tg-auth-trust-row">
                    <div class="tg-auth-trust-item">
                        <div class="tg-auth-trust-num">2 min</div>
                        <div class="tg-auth-trust-label">Setup</div>
                    </div>
                    <div class="tg-auth-trust-item">
                        <div class="tg-auth-trust-num">Free</div>
                        <div class="tg-auth-trust-label">Forever</div>
                    </div>
                    <div class="tg-auth-trust-item">
                        <div class="tg-auth-trust-num">No card</div>
                        <div class="tg-auth-trust-label">Required</div>
                    </div>
                </div>
            </div>
        </div>
    </aside>

    <!-- ── RIGHT: form panel ─────────────────────────────────── -->
    <main class="tg-auth-form-panel" role="main">
        <div class="tg-auth-form-wrap">

            <div class="tg-auth-form-head">
                <a href="/" class="tg-auth-back-link">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                    Back to site
                </a>
                <div class="tg-auth-form-switch">
                    Already a member? <a href="/login">Sign in</a>
                </div>
            </div>

            <div class="tg-auth-form-card">
                <div class="tg-auth-form-card-head">
                    <div class="tg-auth-form-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
                    </div>
                    <h1>Create your account</h1>
                    <p>Join thousands of travelers booking unforgettable getaways. It takes about 2 minutes.</p>
                </div>

                <div id="register-error" class="tg-alert tg-alert-danger" style="display:none;"></div>

                <form id="register-form" novalidate>
                    <div class="tg-auth-field">
                        <label for="name">Full name</label>
                        <div class="tg-auth-input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <input type="text" id="name" name="name" placeholder="Jane Smith" required autocomplete="name">
                        </div>
                    </div>

                    <div class="tg-auth-field">
                        <label for="email">Email address</label>
                        <div class="tg-auth-input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
                            <input type="email" id="email" name="email" placeholder="you@example.com" required autocomplete="email" autocapitalize="none" spellcheck="false">
                        </div>
                    </div>

                    <div class="tg-auth-field">
                        <div class="tg-auth-label-row">
                            <label for="password">Password</label>
                            <span class="tg-auth-hint">8+ characters</span>
                        </div>
                        <div class="tg-auth-input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                            <input type="password" id="password" name="password" placeholder="Create a strong password" required minlength="8" autocomplete="new-password">
                            <button type="button" class="tg-auth-eye" id="toggle-pw" aria-label="Show password" aria-pressed="false">
                                <svg class="eye-on" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                <svg class="eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
                            </button>
                        </div>

                        <!-- Password strength meter -->
                        <div class="tg-auth-strength" id="pw-strength" aria-hidden="true">
                            <div class="tg-auth-strength-bars">
                                <span></span><span></span><span></span><span></span>
                            </div>
                            <span class="tg-auth-strength-label" id="pw-strength-label">Use 8+ characters with a number and a symbol.</span>
                        </div>
                    </div>

                    <div class="tg-auth-field">
                        <label for="password2">Confirm password</label>
                        <div class="tg-auth-input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                            <input type="password" id="password2" name="password2" placeholder="Re-enter your password" required autocomplete="new-password">
                            <span class="tg-auth-match-icon" id="pw-match-icon" aria-hidden="true" style="display:none;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                        </div>
                    </div>

                    <div class="tg-auth-row-between" style="margin-top:14px;">
                        <label class="tg-auth-check">
                            <input type="checkbox" id="terms" required>
                            <span class="tg-auth-check-box" aria-hidden="true">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            <span>
                                I agree to the
                                <a href="/terms" target="_blank" rel="noopener">Terms of Service</a>
                                and
                                <a href="/privacy" target="_blank" rel="noopener">Privacy Policy</a>.
                            </span>
                        </label>
                    </div>

                    <button type="submit" class="tg-auth-submit">
                        <span class="tg-auth-submit-text">Create account</span>
                        <svg class="tg-auth-submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                        <svg class="tg-auth-submit-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg>
                    </button>
                </form>

                <div class="tg-auth-divider"><span>or</span></div>

                <div class="tg-auth-form-foot">
                    <p>Already have a Travlr account?</p>
                    <a href="/login" class="tg-auth-secondary-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                        Sign in instead
                    </a>
                </div>

                <ul class="tg-auth-secure-list" aria-label="Security features">
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        Passwords stored with industry-standard hashing
                    </li>
                    <li>
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12l2 2 4-4"/><path d="M21 12c0 5-3.5 9-9 9s-9-4-9-9 3.5-9 9-9 9 4 9 9z"/></svg>
                        We never sell or share your data
                    </li>
                </ul>
            </div>
        </div>
    </main>

</section>

<script>
(function() {
    /* ── Password show/hide toggle ────────────────────────────── */
    var pwInput = document.getElementById('password');
    var toggle  = document.getElementById('toggle-pw');
    if (pwInput && toggle) {
        var on  = toggle.querySelector('.eye-on');
        var off = toggle.querySelector('.eye-off');
        toggle.addEventListener('click', function() {
            var shown = pwInput.type === 'text';
            pwInput.type = shown ? 'password' : 'text';
            toggle.setAttribute('aria-pressed', String(!shown));
            toggle.setAttribute('aria-label', shown ? 'Show password' : 'Hide password');
            on.style.display  = shown ? '' : 'none';
            off.style.display = shown ? 'none' : '';
        });
    }

    /* ── Password strength meter ──────────────────────────────── */
    var strengthEl = document.getElementById('pw-strength');
    var strengthLabel = document.getElementById('pw-strength-label');
    var bars = strengthEl.querySelectorAll('.tg-auth-strength-bars span');

    function scorePassword(p) {
        if (!p) return { level: 0, label: 'Use 8+ characters with a number and a symbol.' };
        var score = 0;
        if (p.length >= 8)  score++;
        if (p.length >= 12) score++;
        if (/[A-Z]/.test(p) && /[a-z]/.test(p)) score++;
        if (/\d/.test(p))   score++;
        if (/[^A-Za-z0-9]/.test(p)) score++;
        var labels = ['Too short', 'Weak', 'Fair', 'Good', 'Strong'];
        var level  = Math.min(4, Math.max(0, score - 1));
        return { level: level, label: labels[level] };
    }

    pwInput.addEventListener('input', function() {
        var r = scorePassword(pwInput.value);
        strengthEl.setAttribute('data-level', r.level);
        bars.forEach(function(b, i) {
            b.classList.toggle('is-on', i <= r.level);
        });
        strengthLabel.textContent = pwInput.value ? r.label : 'Use 8+ characters with a number and a symbol.';
        checkMatch();
    });

    /* ── Confirm-password match indicator ─────────────────────── */
    var pw2 = document.getElementById('password2');
    var matchIcon = document.getElementById('pw-match-icon');
    function checkMatch() {
        var match = pw2.value && pw2.value === pwInput.value;
        matchIcon.style.display = match ? 'grid' : 'none';
    }
    pw2.addEventListener('input', checkMatch);

    /* ── Submit ───────────────────────────────────────────────── */
    var form       = document.getElementById('register-form');
    var errorEl    = document.getElementById('register-error');
    var submit     = form.querySelector('.tg-auth-submit');
    var submitText = submit.querySelector('.tg-auth-submit-text');
    var submitArrow = submit.querySelector('.tg-auth-submit-arrow');
    var submitSpin  = submit.querySelector('.tg-auth-submit-spin');

    function setLoading(state) {
        if (state) {
            submit.disabled = true;
            submitText.textContent = 'Creating account…';
            submitArrow.style.display = 'none';
            submitSpin.style.display = '';
            submitSpin.classList.add('tg-co-spin');
        } else {
            submit.disabled = false;
            submitText.textContent = 'Create account';
            submitArrow.style.display = '';
            submitSpin.style.display = 'none';
            submitSpin.classList.remove('tg-co-spin');
        }
    }

    function showError(msg) {
        errorEl.textContent = msg;
        errorEl.style.display = 'block';
        errorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    form.addEventListener('submit', async function(e) {
        e.preventDefault();
        errorEl.style.display = 'none';

        var name      = document.getElementById('name').value.trim();
        var email     = document.getElementById('email').value.trim();
        var password  = document.getElementById('password').value;
        var password2 = document.getElementById('password2').value;
        var terms     = document.getElementById('terms').checked;

        if (!name)              { showError('Please enter your full name.'); return; }
        if (!email)             { showError('Please enter your email address.'); return; }
        if (password.length < 8){ showError('Password must be at least 8 characters.'); return; }
        if (password !== password2) { showError('Passwords do not match.'); return; }
        if (!terms)             { showError('Please accept the Terms of Service to continue.'); return; }

        setLoading(true);

        try {
            var res = await fetch('/api/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({ name: name, email: email, password: password })
            });

            var raw = await res.text();
            var data = {};
            try { data = raw ? JSON.parse(raw) : {}; } catch (parseErr) {
                showError('Server returned an unexpected response (HTTP ' + res.status + ').');
                setLoading(false);
                console.error('Non-JSON response from /api/register:', raw);
                return;
            }

            if (res.ok && data.token) {
                localStorage.setItem('travlr-token', data.token);
                submitText.textContent = 'Welcome aboard!';
                var redirect = new URLSearchParams(window.location.search).get('redirect');
                window.location.href = redirect || '/reservations';
            } else {
                showError(data.message || ('Registration failed (HTTP ' + res.status + ').'));
                setLoading(false);
            }
        } catch (err) {
            console.error('Register fetch failed:', err);
            showError('Network error: ' + (err && err.message ? err.message : 'request failed') + '. Is the server running on port 3000?');
            setLoading(false);
        }
    });
})();
</script>

{{> footer}}
