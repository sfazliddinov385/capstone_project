{{> header}}

<div class="tg-page-header">
    <h1>&#128722; Your Cart</h1>
    <p>Review your trips and complete your booking</p>
</div>

<div class="tg-checkout-page">
<div class="tg-checkout-wrap">

    <div id="checkout-loading" style="text-align:center; padding:60px 0;">
        <div style="font-size:2rem; margin-bottom:12px;">&#128336;</div>
        <p style="color:#9ca3af;">Loading your cart&hellip;</p>
    </div>

    <div id="checkout-empty" style="display:none;">
        <div style="background:#fff; border-radius:16px; box-shadow:0 4px 24px rgba(0,0,0,0.07); padding:60px 40px; text-align:center;">
            <div style="font-size:3.5rem; margin-bottom:16px;">&#128722;</div>
            <h2 style="font-family:'Poppins',sans-serif; color:#083050; margin-bottom:12px;">Your cart is empty</h2>
            <p style="color:#6b7280; margin-bottom:28px;">Browse our handpicked destinations and add a trip to get started.</p>
            <a href="/travel" class="btn-primary">Explore Trips &rarr;</a>
        </div>
    </div>

    <div id="checkout-form" style="display:none;">

                        <!-- Cart items injected here -->
                        <div id="cart-items"></div>

                        <!-- Price breakdown -->
                        <div style="background:#f9f9f9; border:1px solid #ddd; border-radius:4px; padding:20px; margin-bottom:28px;">
                            <h3 style="margin:0 0 14px; font-size:1rem; color:#333;">Price Breakdown</h3>
                            <table style="width:100%; font-size:0.92rem; border-collapse:collapse;">
                                <tbody id="fee-rows">
                                    <!-- Trip line items injected by JS -->
                                </tbody>
                                <tbody>
                                    <tr><td colspan="2" style="padding:6px 0;"><hr style="margin:0; border:none; border-top:1px solid #ddd;"></td></tr>
                                    <tr>
                                        <td style="padding:5px 0; color:#555;">Subtotal</td>
                                        <td style="padding:5px 0; text-align:right;" id="co-subtotal">$0.00</td>
                                    </tr>
                                    <tr>
                                        <td style="padding:5px 0; color:#555;">
                                            Taxes &amp; Government Fees
                                            <span style="font-size:0.78rem; color:#999;">(10%)</span>
                                        </td>
                                        <td style="padding:5px 0; text-align:right;" id="co-taxes">$0.00</td>
                                    </tr>
                                    <tr>
                                        <td style="padding:5px 0; color:#555;">
                                            Travlr Service Fee
                                            <span style="font-size:0.78rem; color:#999;">(5%)</span>
                                        </td>
                                        <td style="padding:5px 0; text-align:right;" id="co-service-fee">$0.00</td>
                                    </tr>
                                    <tr id="protection-row" style="display:none;">
                                        <td style="padding:5px 0; color:#555;">Travel Protection</td>
                                        <td style="padding:5px 0; text-align:right;" id="co-protection">$0.00</td>
                                    </tr>
                                    <tr><td colspan="2" style="padding:6px 0;"><hr style="margin:0; border:none; border-top:2px solid #333;"></td></tr>
                                    <tr>
                                        <td style="padding:6px 0; font-weight:bold; font-size:1.05rem;">Total Charge</td>
                                        <td style="padding:6px 0; text-align:right; font-weight:bold; font-size:1.3rem; color:#1a6;" id="co-grand-total">$0.00</td>
                                    </tr>
                                </tbody>
                            </table>

                            <!-- Travel protection opt-in -->
                            <div style="margin-top:16px; padding:12px 14px; background:#fffbea; border:1px solid #e8d96b; border-radius:3px; font-size:0.88rem;">
                                <label style="display:flex; align-items:flex-start; gap:10px; cursor:pointer;">
                                    <input id="opt-protection" type="checkbox" style="margin-top:2px; width:16px; height:16px; flex-shrink:0;">
                                    <span>
                                        <strong>Add Travel Protection &middot; $49 / traveler</strong><br>
                                        <span style="color:#666;">Covers trip cancellations, medical emergencies, lost luggage, and flight delays. Underwritten by TravlrGuard Insurance.</span>
                                    </span>
                                </label>
                            </div>
                        </div>

        <!-- Payment card -->
        <div class="tg-checkout-section">
            <h3>&#128179; Payment Information</h3>
            <p style="font-size:0.82rem; color:#9ca3af; margin:-10px 0 20px; font-style:italic;">
                &#128274; Demo only. No real charges are processed.
            </p>

            <div class="tg-form-group">
                <label>Name on Card <span style="color:#c0392b;">*</span></label>
                <input id="co-card-name" type="text" placeholder="Jane Smith" autocomplete="cc-name">
            </div>

            <div class="tg-form-group">
                <label>Card Number <span style="color:#c0392b;">*</span></label>
                <input id="co-card-number" type="text" placeholder="1234 5678 9012 3456" maxlength="19" autocomplete="cc-number" style="letter-spacing:1.5px;">
            </div>

            <div class="tg-form-row">
                <div class="tg-form-group">
                    <label>Expiry Date <span style="color:#c0392b;">*</span></label>
                    <input id="co-expiry" type="text" placeholder="MM / YY" maxlength="7" autocomplete="cc-exp">
                </div>
                <div class="tg-form-group">
                    <label>CVV <span style="color:#c0392b;">*</span></label>
                    <input id="co-cvv" type="text" placeholder="123" maxlength="4" autocomplete="cc-csc">
                </div>
            </div>

            <div id="checkout-error" class="tg-form-error"></div>
            <div id="checkout-success" class="tg-form-success"></div>

            <div style="display:flex; gap:16px; align-items:center; flex-wrap:wrap; margin-top:8px;">
                <button id="co-confirm" class="btn-primary" style="padding:13px 36px; font-size:1rem;">
                    &#128274; Confirm &amp; Pay
                </button>
                <a href="/travel" style="color:#083050; font-size:0.9rem; font-weight:600;">&#43; Add more trips</a>
            </div>
        </div>

    </div><!-- /.tg-checkout-form -->
</div><!-- /.tg-checkout-wrap -->
</div><!-- /.tg-checkout-page -->

<script>
(async function() {
    var token = localStorage.getItem('travlr-token');
    var cart = [];
    try { cart = JSON.parse(localStorage.getItem('travlr-cart') || '[]'); } catch(e) {}

    document.getElementById('checkout-loading').style.display = 'none';

    if (cart.length === 0) {
        document.getElementById('checkout-empty').style.display = 'block';
        return;
    }

    // Fetch trip details for every cart item in parallel
    var resolved = await Promise.all(cart.map(async function(item) {
        try {
            var r = await fetch('/api/trips/' + encodeURIComponent(item.tripCode));
            if (!r.ok) return null;
            var trip = await r.json();
            return { tripCode: item.tripCode, people: item.people || 1, trip: trip };
        } catch(e) { return null; }
    }));
    resolved = resolved.filter(Boolean);

    if (resolved.length === 0) {
        document.getElementById('checkout-empty').style.display = 'block';
        return;
    }

    var cartItemsEl = document.getElementById('cart-items');

    var TAX_RATE     = 0.10;   // 10% taxes & government fees
    var SERVICE_RATE = 0.05;   // 5% Travlr service fee
    var PROTECTION_PP = 49;    // $49 per traveler for travel protection

    function fmt(n) {
        return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function updateGrandTotal() {
        var subtotal    = 0;
        var totalPeople = 0;

        // Rebuild trip line items in fee-rows
        var feeRows = document.getElementById('fee-rows');
        feeRows.innerHTML = '';
        cartItemsEl.querySelectorAll('.cart-card').forEach(function(card) {
            var price  = parseFloat(card.getAttribute('data-price')) || 0;
            var people = parseInt(card.querySelector('.item-people').textContent, 10) || 1;
            var name   = card.querySelector('h2').textContent.trim();
            var lineTotal = price * people;
            subtotal    += lineTotal;
            totalPeople += people;

            var tr = document.createElement('tr');
            tr.innerHTML =
                '<td style="padding:4px 0; color:#444; font-size:0.88rem;">' +
                    name + ' &times; ' + people + ' traveler' + (people > 1 ? 's' : '') +
                '</td>' +
                '<td style="padding:4px 0; text-align:right; color:#444; font-size:0.88rem;">' +
                    fmt(lineTotal) +
                '</td>';
            feeRows.appendChild(tr);
        });

        var taxes      = subtotal * TAX_RATE;
        var serviceFee = subtotal * SERVICE_RATE;
        var wantsProtection = document.getElementById('opt-protection') && document.getElementById('opt-protection').checked;
        var protection = wantsProtection ? PROTECTION_PP * totalPeople : 0;
        var grand      = subtotal + taxes + serviceFee + protection;

        document.getElementById('co-subtotal').textContent    = fmt(subtotal);
        document.getElementById('co-taxes').textContent       = fmt(taxes);
        document.getElementById('co-service-fee').textContent = fmt(serviceFee);

        if (wantsProtection) {
            document.getElementById('protection-row').style.display = '';
            document.getElementById('co-protection').textContent    = fmt(protection);
        } else {
            document.getElementById('protection-row').style.display = 'none';
        }

        document.getElementById('co-grand-total').textContent = fmt(grand);
    }

    function saveCartFromDOM() {
        var newCart = [];
        cartItemsEl.querySelectorAll('.cart-card').forEach(function(card) {
            newCart.push({
                tripCode: card.getAttribute('data-code'),
                people: parseInt(card.querySelector('.item-people').textContent, 10) || 1
            });
        });
        localStorage.setItem('travlr-cart', JSON.stringify(newCart));
        if (window.refreshCartBadge) window.refreshCartBadge();
    }

    resolved.forEach(function(item) {
        var trip           = item.trip;
        var pricePerPerson = parseFloat(trip.perPerson) || 0;
        var people         = item.people;

        var card = document.createElement('div');
        card.className = 'cart-card tg-checkout-section';
        card.setAttribute('data-code',  trip.code);
        card.setAttribute('data-price', pricePerPerson);
        card.style.cssText = 'margin-bottom:16px;';

        card.innerHTML =
            '<div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:16px;">' +
                '<div>' +
                    '<h2 style="font-family:Poppins,sans-serif; font-size:1.15rem; font-weight:700; color:#083050; margin:0 0 4px;">' + trip.name + '</h2>' +
                    '<span style="font-size:0.78rem; color:#e8b84b; font-weight:700; text-transform:uppercase; letter-spacing:1px;">&#128205; ' + (trip.resort || '') + '</span>' +
                '</div>' +
                '<button class="btn-cancel item-remove" style="border-radius:7px; padding:6px 14px; font-size:0.8rem; font-weight:700; cursor:pointer;">&#10005; Remove</button>' +
            '</div>' +
            '<div style="display:flex; flex-wrap:wrap; gap:8px; margin-bottom:16px;">' +
                '<span style="display:flex;align-items:center;gap:5px;font-size:0.78rem;color:#555;background:#f4f6f9;padding:4px 10px;border-radius:20px;">&#128197; ' + (trip.length || '-') + '</span>' +
                '<span style="display:flex;align-items:center;gap:5px;font-size:0.78rem;color:#555;background:#f4f6f9;padding:4px 10px;border-radius:20px;">&#127775; ' + (trip.start ? new Date(trip.start).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : 'TBD') + '</span>' +
                '<span style="display:flex;align-items:center;gap:5px;font-size:0.78rem;color:#555;background:#f4f6f9;padding:4px 10px;border-radius:20px;">&#128176; $' + pricePerPerson.toLocaleString('en-US',{minimumFractionDigits:2}) + ' / person</span>' +
            '</div>' +
            '<div style="display:flex; align-items:center; gap:12px; border-top:1px solid #f4f6f9; padding-top:16px;">' +
                '<span style="font-size:0.82rem; font-weight:700; color:#374151;">Travelers:</span>' +
                '<button class="tg-btn-counter item-dec">&#8722;</button>' +
                '<span class="item-people" style="min-width:24px; text-align:center; font-size:1rem; font-weight:700;">' + people + '</span>' +
                '<button class="tg-btn-counter item-inc">&#43;</button>' +
                '<span style="font-size:0.85rem; color:#6b7280; margin-left:8px;">Base: <strong class="item-subtotal" style="color:#083050;">$' + (pricePerPerson * people).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '</strong></span>' +
            '</div>';

        // Remove
        card.querySelector('.item-remove').addEventListener('click', function() {
            if (confirm('Remove "' + trip.name + '" from your cart?')) {
                card.remove();
                saveCartFromDOM();
                updateGrandTotal();
                if (cartItemsEl.querySelectorAll('.cart-card').length === 0) {
                    document.getElementById('checkout-form').style.display  = 'none';
                    document.getElementById('checkout-empty').style.display = 'block';
                }
            }
        });

        // Decrement
        card.querySelector('.item-dec').addEventListener('click', function() {
            var el = card.querySelector('.item-people');
            var n  = parseInt(el.textContent, 10);
            if (n > 1) {
                el.textContent = n - 1;
                card.querySelector('.item-subtotal').textContent = '$' + (pricePerPerson * (n - 1)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                saveCartFromDOM();
                updateGrandTotal();
            }
        });

        // Increment
        card.querySelector('.item-inc').addEventListener('click', function() {
            var el = card.querySelector('.item-people');
            var n  = parseInt(el.textContent, 10);
            if (n < 20) {
                el.textContent = n + 1;
                card.querySelector('.item-subtotal').textContent = '$' + (pricePerPerson * (n + 1)).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                saveCartFromDOM();
                updateGrandTotal();
            }
        });

        cartItemsEl.appendChild(card);
    });

    updateGrandTotal();
    document.getElementById('checkout-form').style.display = 'block';

    // Protection checkbox toggles protection row + grand total
    document.getElementById('opt-protection').addEventListener('change', updateGrandTotal);

    // ── Card number formatting ──
    document.getElementById('co-card-number').addEventListener('input', function() {
        var v = this.value.replace(/\D/g, '').slice(0, 16);
        this.value = v.match(/.{1,4}/g) ? v.match(/.{1,4}/g).join(' ') : v;
    });

    // ── Expiry formatting ──
    document.getElementById('co-expiry').addEventListener('input', function() {
        var v = this.value.replace(/\D/g, '').slice(0, 4);
        this.value = v.length >= 3 ? v.slice(0, 2) + ' / ' + v.slice(2) : v;
    });

    // ── CVV digits only ──
    document.getElementById('co-cvv').addEventListener('input', function() {
        this.value = this.value.replace(/\D/g, '').slice(0, 4);
    });

    // ── Confirm & Pay ──
    document.getElementById('co-confirm').addEventListener('click', async function() {
        var errorDiv   = document.getElementById('checkout-error');
        var successDiv = document.getElementById('checkout-success');
        errorDiv.style.display   = 'none';
        successDiv.style.display = 'none';

        // Login check
        token = localStorage.getItem('travlr-token');
        if (!token) {
            showError('You must be logged in to complete your booking. Redirecting to login\u2026');
            setTimeout(function() { window.location.href = '/login?redirect=' + encodeURIComponent(window.location.href); }, 1800);
            return;
        }
        try {
            var pl = JSON.parse(atob(token.split('.')[1]));
            if (pl.exp <= Math.floor(Date.now() / 1000)) throw new Error();
        } catch(e) {
            showError('Your session has expired. Redirecting to login\u2026');
            setTimeout(function() { window.location.href = '/login?redirect=' + encodeURIComponent(window.location.href); }, 1800);
            return;
        }

        // Validate card fields
        var cardName   = document.getElementById('co-card-name').value.trim();
        var cardNumber = document.getElementById('co-card-number').value.replace(/\s/g, '');
        var expiry     = document.getElementById('co-expiry').value.replace(/\s/g, '');
        var cvv        = document.getElementById('co-cvv').value.trim();

        if (!cardName) { showError('Please enter the name on your card.'); return; }
        if (cardNumber.length < 13 || cardNumber.length > 16 || !/^\d+$/.test(cardNumber)) {
            showError('Please enter a valid card number (13 to 16 digits).'); return;
        }
        if (!/^\d{2}\/\d{2}$/.test(expiry)) {
            showError('Please enter a valid expiry date (MM / YY).'); return;
        }
        var expParts = expiry.split('/');
        var expMonth = parseInt(expParts[0], 10);
        var expYear  = parseInt('20' + expParts[1], 10);
        var now      = new Date();
        if (expMonth < 1 || expMonth > 12 || expYear < now.getFullYear() ||
            (expYear === now.getFullYear() && expMonth < now.getMonth() + 1)) {
            showError('Your card appears to be expired.'); return;
        }
        if (cvv.length < 3 || cvv.length > 4) {
            showError('Please enter a valid CVV (3 or 4 digits).'); return;
        }

        var btn = this;
        btn.disabled    = true;
        btn.textContent = 'Processing\u2026';

        // Collect current cart state from DOM
        var currentCart = [];
        cartItemsEl.querySelectorAll('.cart-card').forEach(function(card) {
            currentCart.push({
                tripCode: card.getAttribute('data-code'),
                people:   parseInt(card.querySelector('.item-people').textContent, 10) || 1
            });
        });

        // Book each item
        var failed = [];
        for (var i = 0; i < currentCart.length; i++) {
            try {
                var res  = await fetch('/api/reservations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({ tripCode: currentCart[i].tripCode, people: currentCart[i].people })
                });
                var data = await res.json();
                if (!res.ok) failed.push(data.message || currentCart[i].tripCode);
            } catch(err) {
                failed.push(currentCart[i].tripCode);
            }
        }

        if (failed.length === 0) {
            localStorage.removeItem('travlr-cart');
            if (window.refreshCartBadge) window.refreshCartBadge();
            successDiv.innerHTML = '&#10003; All reservations confirmed! Redirecting to your reservations&hellip;';
            successDiv.style.display = 'block';
            btn.textContent = '&#10003; Confirmed!';
            setTimeout(function() { window.location.href = '/reservations'; }, 2200);
        } else {
            showError('Some bookings failed: ' + failed.join(', ') + '. Please try again.');
            btn.disabled    = false;
            btn.textContent = '&#128274; Confirm & Pay';
        }

        function showError(msg) {
            errorDiv.textContent   = msg;
            errorDiv.style.display = 'block';
        }
    });
})();
</script>
{{> footer}}
