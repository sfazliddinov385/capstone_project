{{> header}}

<!-- ══════════════════════════════════════════════════════
     HERO + step indicator
     ══════════════════════════════════════════════════════ -->
<section class="tg-co-hero">
    <div class="tg-co-hero-bg" aria-hidden="true">
        <div class="tg-travel-blob tg-travel-blob-1"></div>
        <div class="tg-travel-blob tg-travel-blob-2"></div>
        <div class="tg-travel-blob tg-travel-blob-3"></div>
        <div class="tg-travel-grid-overlay"></div>
    </div>
    <div class="tg-co-hero-inner">
        <div class="tg-travel-hero-eyebrow">
            <span class="tg-eyebrow-dot"></span>
            Secure checkout
        </div>
        <h1 class="tg-travel-hero-title">
            Almost <em data-shimmer>there</em>
        </h1>
        <p class="tg-travel-hero-sub">
            Review your trips, add traveler protection if you like, then pay securely.
            Your seats are held while you complete checkout.
        </p>

        <!-- 3-step progress -->
        <div class="tg-co-steps" aria-label="Checkout progress">
            <div class="tg-co-step is-active">
                <div class="tg-co-step-num">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 002 1.6h9.7a2 2 0 002-1.6L23 6H6"/></svg>
                </div>
                <div class="tg-co-step-meta">
                    <div class="tg-co-step-label">Step 1</div>
                    <div class="tg-co-step-title">Your cart</div>
                </div>
            </div>
            <div class="tg-co-step-link"></div>
            <div class="tg-co-step is-active">
                <div class="tg-co-step-num">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                </div>
                <div class="tg-co-step-meta">
                    <div class="tg-co-step-label">Step 2</div>
                    <div class="tg-co-step-title">Payment</div>
                </div>
            </div>
            <div class="tg-co-step-link"></div>
            <div class="tg-co-step">
                <div class="tg-co-step-num">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div class="tg-co-step-meta">
                    <div class="tg-co-step-label">Step 3</div>
                    <div class="tg-co-step-title">Confirmation</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="tg-section tg-section-gray tg-co-section">
    <div class="tg-section-wrap">

        <!-- ── Loading skeleton ─────────────────────────────────── -->
        <div id="checkout-loading" class="tg-co-loading">
            <div class="tg-res-card-skel"></div>
            <div class="tg-res-card-skel"></div>
        </div>

        <!-- ── Empty cart ───────────────────────────────────────── -->
        <div id="checkout-empty" class="tg-empty-state tg-res-empty" style="display:none;">
            <div class="tg-empty-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 002 1.6h9.7a2 2 0 002-1.6L23 6H6"/></svg>
            </div>
            <h3>Your cart is empty</h3>
            <p>Browse handpicked destinations and add a trip to begin checkout.</p>
            <a href="/travel" class="btn-primary btn-primary-pro">
                Explore trips
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
            </a>
        </div>

        <!-- ── Main checkout layout (2-col on desktop) ──────────── -->
        <div id="checkout-form" class="tg-co-grid" style="display:none;">

            <!-- LEFT COLUMN: cart items + payment -->
            <div class="tg-co-main">

                <!-- Cart card -->
                <section class="tg-co-card">
                    <header class="tg-co-card-head">
                        <div class="tg-co-card-head-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 002 1.6h9.7a2 2 0 002-1.6L23 6H6"/></svg>
                        </div>
                        <div>
                            <h2>Your trips</h2>
                            <p>Adjust traveler count or remove items below.</p>
                        </div>
                    </header>
                    <div id="cart-items" class="tg-co-cart-items"></div>
                    <a href="/travel" class="tg-co-add-more">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                        Add another trip
                    </a>
                </section>

                <!-- Travel protection card -->
                <section class="tg-co-card tg-co-protection-card">
                    <label class="tg-co-protection-row">
                        <input id="opt-protection" type="checkbox">
                        <span class="tg-co-protection-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </span>
                        <span class="tg-co-protection-text">
                            <strong>Travel protection · $49 / traveler</strong>
                            <span>Covers cancellations, medical emergencies, lost luggage, and flight delays. Underwritten by TravlrGuard Insurance.</span>
                        </span>
                    </label>
                </section>

                <!-- Payment card -->
                <section class="tg-co-card tg-co-payment-card">
                    <header class="tg-co-card-head">
                        <div class="tg-co-card-head-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                        </div>
                        <div>
                            <h2>Payment</h2>
                            <p>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:14px;height:14px;margin-right:4px;vertical-align:-2px;"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                                Demo mode — no real charges are processed.
                            </p>
                        </div>
                        <div class="tg-co-cardbrands" aria-hidden="true">
                            <span class="tg-co-brand tg-co-brand-visa">VISA</span>
                            <span class="tg-co-brand tg-co-brand-mc">MC</span>
                            <span class="tg-co-brand tg-co-brand-amex">AMEX</span>
                        </div>
                    </header>

                    <div class="tg-co-form-group">
                        <label for="co-card-name">Name on card</label>
                        <div class="tg-co-input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <input id="co-card-name" type="text" placeholder="Jane Smith" autocomplete="cc-name">
                        </div>
                    </div>

                    <div class="tg-co-form-group">
                        <label for="co-card-number">Card number</label>
                        <div class="tg-co-input-wrap">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
                            <input id="co-card-number" type="text" placeholder="1234 5678 9012 3456" maxlength="19" autocomplete="cc-number" inputmode="numeric">
                        </div>
                    </div>

                    <div class="tg-co-form-row">
                        <div class="tg-co-form-group">
                            <label for="co-expiry">Expiry date</label>
                            <div class="tg-co-input-wrap">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <input id="co-expiry" type="text" placeholder="MM / YY" maxlength="7" autocomplete="cc-exp" inputmode="numeric">
                            </div>
                        </div>
                        <div class="tg-co-form-group">
                            <label for="co-cvv">CVV</label>
                            <div class="tg-co-input-wrap">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                                <input id="co-cvv" type="password" placeholder="123" maxlength="4" autocomplete="cc-csc" inputmode="numeric">
                            </div>
                        </div>
                    </div>

                    <div id="checkout-error" class="tg-alert tg-alert-danger" style="display:none; margin-top:14px;"></div>
                    <div id="checkout-success" class="tg-alert tg-alert-success" style="display:none; margin-top:14px;"></div>
                </section>

            </div>

            <!-- RIGHT COLUMN: sticky summary -->
            <aside class="tg-co-aside">
                <div class="tg-co-summary">
                    <h2>Order summary</h2>

                    <div class="tg-co-summary-lines">
                        <table>
                            <tbody id="fee-rows"></tbody>
                            <tbody>
                                <tr class="tg-co-summary-divider"><td colspan="2"></td></tr>
                                <tr>
                                    <td>Subtotal</td>
                                    <td class="tg-co-summary-val" id="co-subtotal">$0.00</td>
                                </tr>
                                <tr>
                                    <td>Taxes &amp; fees <span class="tg-co-summary-pct">10%</span></td>
                                    <td class="tg-co-summary-val" id="co-taxes">$0.00</td>
                                </tr>
                                <tr>
                                    <td>Service fee <span class="tg-co-summary-pct">5%</span></td>
                                    <td class="tg-co-summary-val" id="co-service-fee">$0.00</td>
                                </tr>
                                <tr id="protection-row" style="display:none;">
                                    <td>Travel protection</td>
                                    <td class="tg-co-summary-val" id="co-protection">$0.00</td>
                                </tr>
                                <tr class="tg-co-summary-divider tg-co-summary-divider-strong"><td colspan="2"></td></tr>
                                <tr class="tg-co-summary-grand">
                                    <td>Total</td>
                                    <td class="tg-co-summary-val" id="co-grand-total">$0.00</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <button id="co-confirm" type="button" class="tg-co-pay-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                        Confirm &amp; pay
                    </button>

                    <ul class="tg-co-trust-list">
                        <li>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                            Encrypted SSL checkout
                        </li>
                        <li>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 109-9"/><path d="M21 4L12 13"/></svg>
                            Free cancellation up to 30 days
                        </li>
                        <li>
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                            24/7 traveler support
                        </li>
                    </ul>
                </div>
            </aside>

        </div>

    </div>
</section>

<script>
(async function() {
    var token = localStorage.getItem('travlr-token');
    var cart = [];
    try { cart = JSON.parse(localStorage.getItem('travlr-cart') || '[]'); } catch(e) {}

    var loadingEl = document.getElementById('checkout-loading');
    if (loadingEl) loadingEl.style.display = 'none';

    if (cart.length === 0) {
        document.getElementById('checkout-empty').style.display = 'flex';
        return;
    }

    // Fetch trip details for every cart item in parallel
    var resolved = await Promise.all(cart.map(async function(item) {
        try {
            var r = await fetch('/api/trips/' + encodeURIComponent(item.tripCode));
            if (!r.ok) return null;
            var trip = await r.json();
            return { tripCode: item.tripCode, people: item.people || 1, trip: trip };
        } catch(e) { return null; }
    }));
    resolved = resolved.filter(Boolean);

    if (resolved.length === 0) {
        document.getElementById('checkout-empty').style.display = 'flex';
        return;
    }

    var cartItemsEl = document.getElementById('cart-items');

    var TAX_RATE     = 0.10;
    var SERVICE_RATE = 0.05;
    var PROTECTION_PP = 49;

    function fmt(n) {
        return '$' + n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function escapeHtml(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function updateGrandTotal() {
        var subtotal    = 0;
        var totalPeople = 0;

        var feeRows = document.getElementById('fee-rows');
        feeRows.innerHTML = '';
        cartItemsEl.querySelectorAll('.cart-card').forEach(function(card) {
            var price  = parseFloat(card.getAttribute('data-price')) || 0;
            var people = parseInt(card.querySelector('.item-people').textContent, 10) || 1;
            var name   = card.querySelector('h3').textContent.trim();
            var lineTotal = price * people;
            subtotal    += lineTotal;
            totalPeople += people;

            var tr = document.createElement('tr');
            tr.className = 'tg-co-summary-line';
            tr.innerHTML =
                '<td>' + escapeHtml(name) + ' <span class="tg-co-summary-mult">× ' + people + '</span></td>' +
                '<td class="tg-co-summary-val">' + fmt(lineTotal) + '</td>';
            feeRows.appendChild(tr);
        });

        var taxes      = subtotal * TAX_RATE;
        var serviceFee = subtotal * SERVICE_RATE;
        var wantsProtection = document.getElementById('opt-protection') && document.getElementById('opt-protection').checked;
        var protection = wantsProtection ? PROTECTION_PP * totalPeople : 0;
        var grand      = subtotal + taxes + serviceFee + protection;

        document.getElementById('co-subtotal').textContent    = fmt(subtotal);
        document.getElementById('co-taxes').textContent       = fmt(taxes);
        document.getElementById('co-service-fee').textContent = fmt(serviceFee);

        if (wantsProtection) {
            document.getElementById('protection-row').style.display = '';
            document.getElementById('co-protection').textContent    = fmt(protection);
        } else {
            document.getElementById('protection-row').style.display = 'none';
        }

        document.getElementById('co-grand-total').textContent = fmt(grand);
    }

    function saveCartFromDOM() {
        var newCart = [];
        cartItemsEl.querySelectorAll('.cart-card').forEach(function(card) {
            newCart.push({
                tripCode: card.getAttribute('data-code'),
                people: parseInt(card.querySelector('.item-people').textContent, 10) || 1
            });
        });
        localStorage.setItem('travlr-cart', JSON.stringify(newCart));
        if (window.refreshCartBadge) window.refreshCartBadge();
    }

    /* deterministic gradient per trip name */
    function destClass(name) {
        var sum = 0;
        for (var i = 0; i < (name || '').length; i++) sum = (sum + name.charCodeAt(i)) % 6;
        return 'tg-res-dest-' + (sum + 1);
    }

    resolved.forEach(function(item) {
        var trip           = item.trip;
        var pricePerPerson = parseFloat(trip.perPerson) || 0;
        var people         = item.people;

        var card = document.createElement('article');
        card.className = 'cart-card tg-co-trip';
        card.setAttribute('data-code',  trip.code);
        card.setAttribute('data-price', pricePerPerson);

        var startDate = trip.start ? new Date(trip.start).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : 'TBD';

        card.innerHTML =
            '<div class="tg-co-trip-thumb ' + destClass(trip.name) + '" aria-hidden="true">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>' +
            '</div>' +
            '<div class="tg-co-trip-body">' +
                '<div class="tg-co-trip-head">' +
                    '<div>' +
                        '<div class="tg-co-trip-code">' + escapeHtml(trip.code) + '</div>' +
                        '<h3>' + escapeHtml(trip.name) + '</h3>' +
                        '<div class="tg-co-trip-resort">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>' +
                            escapeHtml(trip.resort || '—') +
                        '</div>' +
                    '</div>' +
                    '<button type="button" class="tg-co-trip-remove item-remove" aria-label="Remove ' + escapeHtml(trip.name) + ' from cart">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                    '</button>' +
                '</div>' +
                '<div class="tg-co-trip-chips">' +
                    '<span class="tg-co-chip">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>' +
                        escapeHtml(trip.length || '—') +
                    '</span>' +
                    '<span class="tg-co-chip">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
                        startDate +
                    '</span>' +
                    '<span class="tg-co-chip">' +
                        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>' +
                        fmt(pricePerPerson) + ' / person' +
                    '</span>' +
                '</div>' +
                '<div class="tg-co-trip-foot">' +
                    '<div class="tg-co-counter">' +
                        '<span class="tg-co-counter-label">Travelers</span>' +
                        '<button type="button" class="tg-co-counter-btn item-dec" aria-label="Decrease travelers">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/></svg>' +
                        '</button>' +
                        '<span class="item-people tg-co-counter-num">' + people + '</span>' +
                        '<button type="button" class="tg-co-counter-btn item-inc" aria-label="Increase travelers">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>' +
                        '</button>' +
                    '</div>' +
                    '<div class="tg-co-trip-subtotal">' +
                        '<span class="tg-co-trip-subtotal-label">Base price</span>' +
                        '<strong class="item-subtotal">' + fmt(pricePerPerson * people) + '</strong>' +
                    '</div>' +
                '</div>' +
            '</div>';

        card.querySelector('.item-remove').addEventListener('click', function() {
            if (confirm('Remove "' + trip.name + '" from your cart?')) {
                card.remove();
                saveCartFromDOM();
                updateGrandTotal();
                if (cartItemsEl.querySelectorAll('.cart-card').length === 0) {
                    document.getElementById('checkout-form').style.display  = 'none';
                    document.getElementById('checkout-empty').style.display = 'flex';
                }
            }
        });

        card.querySelector('.item-dec').addEventListener('click', function() {
            var el = card.querySelector('.item-people');
            var n  = parseInt(el.textContent, 10);
            if (n > 1) {
                el.textContent = n - 1;
                card.querySelector('.item-subtotal').textContent = fmt(pricePerPerson * (n - 1));
                saveCartFromDOM();
                updateGrandTotal();
            }
        });

        card.querySelector('.item-inc').addEventListener('click', function() {
            var el = card.querySelector('.item-people');
            var n  = parseInt(el.textContent, 10);
            if (n < 20) {
                el.textContent = n + 1;
                card.querySelector('.item-subtotal').textContent = fmt(pricePerPerson * (n + 1));
                saveCartFromDOM();
                updateGrandTotal();
            }
        });

        cartItemsEl.appendChild(card);
    });

    updateGrandTotal();
    document.getElementById('checkout-form').style.display = 'grid';

    document.getElementById('opt-protection').addEventListener('change', updateGrandTotal);

    // ── Card number formatting ──
    document.getElementById('co-card-number').addEventListener('input', function() {
        var v = this.value.replace(/\D/g, '').slice(0, 16);
        this.value = v.match(/.{1,4}/g) ? v.match(/.{1,4}/g).join(' ') : v;
        // Highlight brand
        var brands = document.querySelectorAll('.tg-co-brand');
        brands.forEach(function(b) { b.classList.remove('is-active'); });
        if (/^4/.test(v))      document.querySelector('.tg-co-brand-visa').classList.add('is-active');
        else if (/^5[1-5]/.test(v) || /^2[2-7]/.test(v)) document.querySelector('.tg-co-brand-mc').classList.add('is-active');
        else if (/^3[47]/.test(v)) document.querySelector('.tg-co-brand-amex').classList.add('is-active');
    });

    document.getElementById('co-expiry').addEventListener('input', function() {
        var v = this.value.replace(/\D/g, '').slice(0, 4);
        this.value = v.length >= 3 ? v.slice(0, 2) + ' / ' + v.slice(2) : v;
    });

    document.getElementById('co-cvv').addEventListener('input', function() {
        this.value = this.value.replace(/\D/g, '').slice(0, 4);
    });

    document.getElementById('co-confirm').addEventListener('click', async function() {
        var errorDiv   = document.getElementById('checkout-error');
        var successDiv = document.getElementById('checkout-success');
        errorDiv.style.display   = 'none';
        successDiv.style.display = 'none';

        function showError(msg) {
            errorDiv.textContent   = msg;
            errorDiv.style.display = 'block';
            errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        token = localStorage.getItem('travlr-token');
        if (!token) {
            showError('You must be logged in to complete your booking. Redirecting to login…');
            setTimeout(function() { window.location.href = '/login?redirect=' + encodeURIComponent(window.location.href); }, 1800);
            return;
        }
        try {
            var pl = JSON.parse(atob(token.split('.')[1]));
            if (pl.exp <= Math.floor(Date.now() / 1000)) throw new Error();
        } catch (e) {
            showError('Your session has expired. Redirecting to login…');
            setTimeout(function() { window.location.href = '/login?redirect=' + encodeURIComponent(window.location.href); }, 1800);
            return;
        }

        var cardName   = document.getElementById('co-card-name').value.trim();
        var cardNumber = document.getElementById('co-card-number').value.replace(/\s/g, '');
        var expiry     = document.getElementById('co-expiry').value.replace(/\s/g, '');
        var cvv        = document.getElementById('co-cvv').value.trim();

        if (!cardName) { showError('Please enter the name on your card.'); return; }
        if (cardNumber.length < 13 || cardNumber.length > 16 || !/^\d+$/.test(cardNumber)) {
            showError('Please enter a valid card number (13 to 16 digits).'); return;
        }
        if (!/^\d{2}\/\d{2}$/.test(expiry)) {
            showError('Please enter a valid expiry date (MM / YY).'); return;
        }
        var expParts = expiry.split('/');
        var expMonth = parseInt(expParts[0], 10);
        var expYear  = parseInt('20' + expParts[1], 10);
        var now      = new Date();
        if (expMonth < 1 || expMonth > 12 || expYear < now.getFullYear() ||
            (expYear === now.getFullYear() && expMonth < now.getMonth() + 1)) {
            showError('Your card appears to be expired.'); return;
        }
        if (cvv.length < 3 || cvv.length > 4) {
            showError('Please enter a valid CVV (3 or 4 digits).'); return;
        }

        var btn = this;
        var origHtml = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="tg-co-spin" aria-hidden="true"><path d="M21 12a9 9 0 11-6.219-8.56"/></svg> Processing…';

        var currentCart = [];
        cartItemsEl.querySelectorAll('.cart-card').forEach(function(card) {
            currentCart.push({
                tripCode: card.getAttribute('data-code'),
                people:   parseInt(card.querySelector('.item-people').textContent, 10) || 1
            });
        });

        var failed = [];
        for (var i = 0; i < currentCart.length; i++) {
            try {
                var res  = await fetch('/api/reservations', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                    body: JSON.stringify({ tripCode: currentCart[i].tripCode, people: currentCart[i].people })
                });
                var data = await res.json();
                if (!res.ok) failed.push(data.message || currentCart[i].tripCode);
            } catch(err) {
                failed.push(currentCart[i].tripCode);
            }
        }

        if (failed.length === 0) {
            localStorage.removeItem('travlr-cart');
            if (window.refreshCartBadge) window.refreshCartBadge();
            successDiv.innerHTML = '<strong>✓ All reservations confirmed!</strong> Redirecting to your reservations…';
            successDiv.style.display = 'block';
            btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg> Confirmed';
            setTimeout(function() { window.location.href = '/reservations'; }, 2200);
        } else {
            showError('Some bookings failed: ' + failed.join(', ') + '. Please try again.');
            btn.disabled = false;
            btn.innerHTML = origHtml;
        }
    });
})();
</script>

