{{> header}}

<!-- Hero -->
<div class="tg-meals-hero">
    <div class="tg-meals-hero-inner">
        <span class="tg-hero-eyebrow">Resort Dining</span>
        <h1>Eat like a <em>guest</em>, feel like a <em>local</em>.</h1>
        <p>Every Travlr Getaways property pairs with a small kitchen team that cooks with what arrived that morning. Ocean-to-table seafood, scratch-made pastries, and a buffet that changes by the day.</p>
        <div class="tg-meals-hero-stats">
            <div><strong>3</strong><span>Restaurants per resort</span></div>
            <div><strong>24/7</strong><span>In-room dining</span></div>
            <div><strong>0</strong><span>Hidden fees</span></div>
        </div>
    </div>
</div>

<!-- Featured experiences -->
<section class="tg-section tg-section-gray">
    <div class="tg-section-wrap">
        <div class="tg-section-head">
            <span class="tg-about-eyebrow">Three signature experiences</span>
            <h2>What you can expect on the menu</h2>
            <p class="tg-section-sub">A rotating selection across breakfast, lunch, and dinner. Menus change with the season and what the local market has that week.</p>
        </div>

        <div class="tg-meals-grid">

            <article class="tg-meal-card">
                <div class="tg-meal-img">
                    <img src="/images/seafoods.jpg" alt="Fresh seafood platter" loading="lazy">
                    <span class="tg-meal-badge tg-meal-badge-signature">Signature</span>
                </div>
                <div class="tg-meal-body">
                    <div class="tg-meal-course">Dinner Service</div>
                    <h3>Seafood Feast</h3>
                    <p>A rotating selection of the ocean&rsquo;s finest. Whole steamed lobster, pan-seared salmon fillets, and delicately plated white fish with citrus glaze. Prepared fresh daily by our resort chefs using locally sourced seafood.</p>
                    <ul class="tg-meal-tags">
                        <li>Lobster</li>
                        <li>Wild salmon</li>
                        <li>Citrus glaze</li>
                        <li>Local catch</li>
                    </ul>
                    <div class="tg-meal-footer">
                        <span class="tg-meal-where">Available at the Harbor restaurant</span>
                    </div>
                </div>
            </article>

            <article class="tg-meal-card">
                <div class="tg-meal-img">
                    <img src="/images/desserts.jpg" alt="Dessert selection" loading="lazy">
                    <span class="tg-meal-badge tg-meal-badge-sweet">Sweet</span>
                </div>
                <div class="tg-meal-body">
                    <div class="tg-meal-course">All Day</div>
                    <h3>Sumptuous Desserts</h3>
                    <p>Indulge in our signature dessert selection. A warm chocolate lava cake drizzled with rich fudge sauce, a double-chocolate ice cream sandwich with creamy filling, and a golden Belgian waffle topped with fresh berries and whipped cream.</p>
                    <ul class="tg-meal-tags">
                        <li>Chocolate lava cake</li>
                        <li>Ice cream sandwich</li>
                        <li>Belgian waffles</li>
                        <li>Fresh berries</li>
                    </ul>
                    <div class="tg-meal-footer">
                        <span class="tg-meal-where">Available at the Patisserie and via room service</span>
                    </div>
                </div>
            </article>

            <article class="tg-meal-card">
                <div class="tg-meal-img">
                    <img src="/images/buffet.jpg" alt="Buffet spread" loading="lazy">
                    <span class="tg-meal-badge tg-meal-badge-family">All Day</span>
                </div>
                <div class="tg-meal-body">
                    <div class="tg-meal-course">Breakfast &middot; Lunch</div>
                    <h3>Mixed Buffet</h3>
                    <p>A hearty spread for every appetite. Herb-crusted salmon and grilled fish platters, a vibrant arrangement of fresh tropical fruits including pineapple, mango, and grapes, and an assortment of gourmet deli sandwiches and submarine rolls.</p>
                    <ul class="tg-meal-tags">
                        <li>Tropical fruits</li>
                        <li>Grilled fish</li>
                        <li>Deli sandwiches</li>
                        <li>Carved meats</li>
                    </ul>
                    <div class="tg-meal-footer">
                        <span class="tg-meal-where">Available at the Atrium dining hall</span>
                    </div>
                </div>
            </article>

        </div>
    </div>
</section>

<!-- Daily schedule -->
<section class="tg-section">
    <div class="tg-section-wrap">
        <div class="tg-section-head">
            <span class="tg-about-eyebrow">A typical day</span>
            <h2>From first coffee to last cocktail</h2>
            <p class="tg-section-sub">Four service windows, all included in your trip price. Allergies and dietary needs are noted at check-in and respected at every meal.</p>
        </div>

        <div class="tg-schedule-grid">
            <div class="tg-schedule-card">
                <div class="tg-schedule-icon">&#9749;</div>
                <div class="tg-schedule-time">6:30 to 10:30 am</div>
                <h4>Breakfast</h4>
                <p>Hot pastries, made-to-order omelets, tropical fruit, espresso bar, fresh-pressed juices.</p>
            </div>
            <div class="tg-schedule-card">
                <div class="tg-schedule-icon">&#129367;</div>
                <div class="tg-schedule-time">12:00 to 2:30 pm</div>
                <h4>Lunch</h4>
                <p>Mixed buffet at the Atrium, plus a la carte poolside menu with salads, wood-fired pizza, and grilled fish.</p>
            </div>
            <div class="tg-schedule-card">
                <div class="tg-schedule-icon">&#127869;&#65039;</div>
                <div class="tg-schedule-time">6:00 to 10:00 pm</div>
                <h4>Dinner</h4>
                <p>Three-course plated service at the Harbor. Seafood feast on the menu most nights, with a vegetarian alternative always available.</p>
            </div>
            <div class="tg-schedule-card">
                <div class="tg-schedule-icon">&#127864;</div>
                <div class="tg-schedule-time">10:00 pm to late</div>
                <h4>Late Night</h4>
                <p>Bar menu of small plates and signature cocktails. In-room dining stays open 24 hours for the night-owl in your party.</p>
            </div>
        </div>
    </div>
</section>

<!-- Dining moments gallery -->
<section class="tg-section tg-section-gray">
    <div class="tg-section-wrap">
        <div class="tg-section-head">
            <span class="tg-about-eyebrow">Dining moments</span>
            <h2>Snapshots from our partner kitchens</h2>
            <p class="tg-section-sub">Four real meals served at Travlr Getaways resorts in the past month. Every photo is from a partner property currently on the catalog.</p>
        </div>

        <div class="tg-dining-gallery">
            <figure class="tg-dining-tile">
                <img src="/images/seaside-breakfast.jpg" alt="Sunrise breakfast over the caldera in Santorini" loading="lazy">
                <figcaption>
                    <span class="tg-dining-place">&#127465;&#127479; Santorini, Greece</span>
                    <strong>Sunrise breakfast on the caldera</strong>
                    <span class="tg-dining-where">Aegean Bliss Retreat</span>
                </figcaption>
            </figure>

            <figure class="tg-dining-tile">
                <img src="/images/tasting-spread.jpg" alt="Late-night tasting spread of Korean fried chicken and side dishes" loading="lazy">
                <figcaption>
                    <span class="tg-dining-place">&#127472;&#127479; Seoul, Korea</span>
                    <strong>Late-night fried chicken tasting</strong>
                    <span class="tg-dining-where">Gangnam Heights Resort</span>
                </figcaption>
            </figure>

            <figure class="tg-dining-tile">
                <img src="/images/grill-satay.jpg" alt="Satay skewers grilling over coconut-husk charcoal" loading="lazy">
                <figcaption>
                    <span class="tg-dining-place">&#127470;&#127465; Ubud, Indonesia</span>
                    <strong>Night-market satay over coconut charcoal</strong>
                    <span class="tg-dining-where">Bali Spirit Lodge</span>
                </figcaption>
            </figure>

            <figure class="tg-dining-tile">
                <img src="/images/greek-salad.jpg" alt="Greek salad with feta served with an ocean view" loading="lazy">
                <figcaption>
                    <span class="tg-dining-place">&#127465;&#127479; Mykonos, Greece</span>
                    <strong>Garden Greek salad with sea views</strong>
                    <span class="tg-dining-where">MS Riviera Mediterranean Cruise</span>
                </figcaption>
            </figure>
        </div>
    </div>
</section>

<!-- Dietary -->
<section class="tg-section">
    <div class="tg-section-wrap">
        <div class="tg-section-head">
            <span class="tg-about-eyebrow">Dietary needs covered</span>
            <h2>Tell us once, we remember every meal</h2>
            <p class="tg-section-sub">At check-in we ask about allergies, preferences, and any restrictions. Your dietary profile is shared with every chef at the resort.</p>
        </div>

        <div class="tg-diet-grid">
            <div class="tg-diet-chip">
                <div class="tg-diet-icon">&#129382;</div>
                <strong>Vegetarian</strong>
                <span>Plant-forward options at every meal, not just sides.</span>
            </div>
            <div class="tg-diet-chip">
                <div class="tg-diet-icon">&#127793;</div>
                <strong>Vegan</strong>
                <span>Fully vegan menu available on request, prepared in a dedicated station.</span>
            </div>
            <div class="tg-diet-chip">
                <div class="tg-diet-icon">&#127806;</div>
                <strong>Gluten-Free</strong>
                <span>Certified gluten-free bread, pasta, and pastry options daily.</span>
            </div>
            <div class="tg-diet-chip">
                <div class="tg-diet-icon">&#128332;</div>
                <strong>Halal</strong>
                <span>Halal-certified meats and a separated prep area on request.</span>
            </div>
            <div class="tg-diet-chip">
                <div class="tg-diet-icon">&#10017;&#65039;</div>
                <strong>Kosher</strong>
                <span>Kosher meals available with 48 hours notice before arrival.</span>
            </div>
            <div class="tg-diet-chip">
                <div class="tg-diet-icon">&#129372;</div>
                <strong>Nut-Free</strong>
                <span>Severe nut allergies flagged on every ticket, every service.</span>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="tg-about-cta">
    <div class="tg-section-wrap">
        <div class="tg-about-cta-inner">
            <h2>Hungry yet?</h2>
            <p>Browse the trips and you&rsquo;ll see which restaurants are at each resort, sample menus included.</p>
            <div class="tg-about-cta-row" style="justify-content:center;">
                <a href="/travel" class="btn-about-primary">Browse trips &rarr;</a>
                <a href="/contact" class="btn-about-secondary btn-about-secondary-light">Talk to a chef</a>
            </div>
        </div>
    </div>
</section>

{{> footer}}
