{{> header}}

<!-- Breadcrumb -->
<nav aria-label="Breadcrumb" class="tg-crumb">
    <div class="tg-crumb-wrap">
        <a href="/">Home</a>
        <span aria-hidden="true">&rsaquo;</span>
        <a href="/travel">Trips</a>
        <span aria-hidden="true">&rsaquo;</span>
        <span aria-current="page">{{trip.name}}</span>
    </div>
</nav>

<!-- Hero with single large image and overlay info -->
<section class="tg-detail-hero" style="background-image: linear-gradient(180deg, rgba(8,32,56,0.0), rgba(8,32,56,0.7)), url('{{trip.image}}');">
    <div class="tg-detail-hero-inner">
        <div class="tg-detail-hero-badges">
            <span class="tg-detail-badge tg-detail-badge-category">{{trip.category}}</span>
            <span class="tg-detail-badge tg-detail-badge-diff" data-difficulty="{{trip.difficulty}}">{{trip.difficulty}}</span>
            {{#if (lte trip.spotsLeft 5)}}
                <span class="tg-detail-badge tg-detail-badge-urgent" aria-live="polite">&#9888; Only {{trip.spotsLeft}} spot{{#unless (lte trip.spotsLeft 1)}}s{{/unless}} left!</span>
            {{/if}}
        </div>
        <h1>{{trip.name}}</h1>
        <p class="tg-detail-resort">
            <svg class="tg-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {{trip.resort}}
        </p>
        <div class="tg-detail-meta">
            <div class="tg-meta-pill">
                <svg class="tg-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {{trip.length}}
            </div>
            <div class="tg-meta-pill">
                <svg class="tg-detail-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16l-9 5-9-5V8l9-5 9 5v8z"/><path d="M3 8l9 5 9-5"/></svg>
                Departs {{trip.departureCity}}
            </div>
            <div class="tg-meta-pill">
                <svg class="tg-detail-icon" viewBox="0 0 24 24" fill="#e8b84b" stroke="#e8b84b"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {{trip.rating}} <span style="color:rgba(255,255,255,0.75);">({{trip.reviewCount}} reviews)</span>
            </div>
        </div>
    </div>
</section>

<!-- Main content + sticky booking sidebar -->
<section class="tg-detail-body">
    <div class="tg-detail-grid">

        <!-- LEFT: details -->
        <article class="tg-detail-main">

            <!-- Description -->
            <div class="tg-detail-block">
                <h2>About this trip</h2>
                <p class="tg-detail-desc">{{trip.description}}</p>
            </div>

            <!-- What's included -->
            <div class="tg-detail-block">
                <h2>What's included</h2>
                <ul class="tg-detail-includes">
                    {{#each trip.includes}}
                        <li>
                            <svg class="tg-check" viewBox="0 0 24 24" fill="none" stroke="#0f8a4a" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            {{this}}
                        </li>
                    {{/each}}
                </ul>
            </div>

            <!-- Reviews -->
            <div class="tg-detail-block">
                <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
                    <h2 style="margin:0;">Traveler Reviews</h2>
                    <span class="tg-detail-review-summary">
                        <strong>{{trip.rating}}</strong> &middot; based on <span id="rev-count">{{trip.reviewCount}}</span> reviews
                    </span>
                </div>
                <div id="reviews-list" class="tg-reviews">
                    <p style="color:#9ca3af; font-style:italic; padding:18px 0;">Loading reviews&hellip;</p>
                </div>
            </div>

        </article>

        <!-- RIGHT: sticky booking card -->
        <aside class="tg-detail-aside">
            <div class="tg-book-card">
                <div class="tg-book-price">
                    <span class="tg-book-price-amount">${{trip.perPerson}}</span>
                    <span class="tg-book-price-per">/ person</span>
                </div>

                <div class="tg-book-stat">
                    <span class="tg-book-stat-label">Departure</span>
                    <span class="tg-book-stat-val">{{trip.departureCity}}</span>
                </div>
                <div class="tg-book-stat">
                    <span class="tg-book-stat-label">Duration</span>
                    <span class="tg-book-stat-val">{{trip.length}}</span>
                </div>
                <div class="tg-book-stat">
                    <span class="tg-book-stat-label">Seats left</span>
                    <span class="tg-book-stat-val">{{trip.spotsLeft}}</span>
                </div>

                <!-- Traveler count selector -->
                <div class="tg-book-people">
                    <span class="tg-book-people-label">Travelers</span>
                    <div class="tg-book-people-ctrl">
                        <button type="button" id="people-dec" class="tg-book-step" aria-label="Decrease travelers">&#8722;</button>
                        <span id="people-val" class="tg-book-people-num" aria-live="polite">1</span>
                        <button type="button" id="people-inc" class="tg-book-step" aria-label="Increase travelers">+</button>
                    </div>
                </div>
                <div class="tg-book-total">
                    <span>Total</span>
                    <strong id="book-total">${{trip.perPerson}}</strong>
                </div>

                <div id="book-msg" class="tg-book-msg" style="display:none;"></div>

                <button id="book-btn" class="btn-primary tg-book-cta" data-code="{{trip.code}}" data-price="{{trip.perPerson}}" data-seats="{{trip.spotsLeft}}">
                    Reserve Now &rarr;
                </button>
                <button id="fav-btn" class="tg-book-fav" data-code="{{trip.code}}" aria-pressed="false">
                    <svg class="tg-heart" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                    <span id="fav-label">Save to Favorites</span>
                </button>

                <p class="tg-book-disclaimer">No charge today &middot; cancel anytime before departure.</p>
            </div>
        </aside>

    </div>

    <!-- Similar trips -->
    <div class="tg-detail-similar">
        <div style="max-width:1280px; margin:0 auto; padding:0 32px;">
            <h2 style="font-family:'Poppins',sans-serif; font-size:1.6rem; color:#083050; margin-bottom:20px;">You might also like</h2>
            <div id="similar-grid" class="tg-grid">
                <p style="color:#9ca3af; font-style:italic;">Finding similar trips&hellip;</p>
            </div>
        </div>
    </div>
</section>

<script>
(function() {
    var tripCode  = '{{trip.code}}';
    var perPerson = parseFloat('{{trip.perPerson}}') || 0;
    var token     = localStorage.getItem('travlr-token');

    // ── Reviews ────────────────────────────────────────────────
    var revBox = document.getElementById('reviews-list');
    fetch('/api/trips/' + tripCode + '/reviews')
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(reviews) {
            if (!reviews.length) {
                revBox.innerHTML = '<p style="color:#6b7280; padding:18px 0;">No reviews yet for this trip. Book it and be the first to share your experience!</p>';
                return;
            }
            revBox.innerHTML = reviews.map(function(r) {
                var stars = '';
                for (var i = 1; i <= 5; i++) {
                    stars += '<span style="color:' + (i <= r.rating ? '#e8b84b' : '#d1d5db') + ';">&#9733;</span>';
                }
                var date = r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' }) : '';
                var initial = (r.userName || 'T').charAt(0).toUpperCase();

                // Operator response block, only when the admin has replied.
                var replyHtml = '';
                if (r.adminReply && String(r.adminReply).trim()) {
                    var replyDate = r.adminReplyAt
                        ? new Date(r.adminReplyAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' })
                        : '';
                    replyHtml = ''
                        + '<div class="tg-review-reply">'
                        +   '<div class="tg-review-reply-head">'
                        +     '<span class="tg-review-reply-badge">Response from ' + escapeHtml(r.adminReplyByName || 'Travlr Getaways') + '</span>'
                        +     (replyDate ? '<span class="tg-review-reply-date">' + escapeHtml(replyDate) + '</span>' : '')
                        +   '</div>'
                        +   '<p class="tg-review-reply-text">' + escapeHtml(r.adminReply) + '</p>'
                        + '</div>';
                }

                return ''
                    + '<article class="tg-review">'
                    +   '<div class="tg-review-head">'
                    +     '<div class="tg-review-avatar">' + initial + '</div>'
                    +     '<div>'
                    +       '<div class="tg-review-name">' + escapeHtml(r.userName || 'Traveler') + '</div>'
                    +       '<div class="tg-review-meta">' + stars + ' &middot; ' + escapeHtml(date) + '</div>'
                    +     '</div>'
                    +   '</div>'
                    +   '<p class="tg-review-text">' + escapeHtml(r.comment || '') + '</p>'
                    +   replyHtml
                    + '</article>';
            }).join('');
        })
        .catch(function() {
            revBox.innerHTML = '<p style="color:#9ca3af;">Could not load reviews.</p>';
        });

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, function(c) {
            return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
        });
    }

    // ── Similar trips ──────────────────────────────────────────
    var simBox = document.getElementById('similar-grid');
    fetch('/api/trips/' + tripCode + '/similar')
        .then(function(r) { return r.ok ? r.json() : []; })
        .then(function(trips) {
            if (!trips.length) { simBox.innerHTML = '<p style="color:#9ca3af;">No similar trips found.</p>'; return; }
            simBox.innerHTML = trips.map(function(t) {
                return ''
                    + '<a href="/trip/' + t.code + '" class="tg-card tg-card-link">'
                    +   '<div class="tg-card-img"><img src="' + t.image + '" alt="' + escapeHtml(t.name) + '" loading="lazy" onerror="this.src=\'/images/sea-sound.jpg\'"></div>'
                    +   '<div class="tg-card-body">'
                    +     '<div class="tg-card-resort">' + escapeHtml(t.resort || '') + '</div>'
                    +     '<div class="tg-card-title">' + escapeHtml(t.name) + '</div>'
                    +     '<div class="tg-card-price"><span class="tg-price-amount">$' + t.perPerson + '</span><span class="tg-price-per">/ person</span></div>'
                    +   '</div>'
                    + '</a>';
            }).join('');
        })
        .catch(function() { simBox.innerHTML = '<p style="color:#9ca3af;">Could not load similar trips.</p>'; });

    // ── Favorite toggle ────────────────────────────────────────
    var favBtn = document.getElementById('fav-btn');
    var favLbl = document.getElementById('fav-label');
    var isFav  = false;

    function paintFav() {
        favBtn.setAttribute('aria-pressed', String(isFav));
        favBtn.classList.toggle('is-active', isFav);
        favLbl.textContent = isFav ? 'Saved' : 'Save to Favorites';
    }

    if (token) {
        fetch('/api/favorites/codes', { headers: { 'Authorization': 'Bearer ' + token } })
            .then(function(r) { return r.ok ? r.json() : []; })
            .then(function(codes) { isFav = codes.indexOf(tripCode) !== -1; paintFav(); })
            .catch(function() {});
    }

    favBtn.addEventListener('click', async function() {
        if (!token) { window.location.href = '/login'; return; }
        favBtn.disabled = true;
        try {
            var method = isFav ? 'DELETE' : 'POST';
            var r = await fetch('/api/favorites/' + tripCode, { method: method, headers: { 'Authorization': 'Bearer ' + token } });
            if (r.ok) { isFav = !isFav; paintFav(); }
        } catch (e) {} finally { favBtn.disabled = false; }
    });

    // ── Inline traveler counter ────────────────────────────────
    var bookBtn   = document.getElementById('book-btn');
    var peopleVal = document.getElementById('people-val');
    var totalEl   = document.getElementById('book-total');
    var msgEl     = document.getElementById('book-msg');
    var maxSeats  = parseInt(bookBtn.getAttribute('data-seats'), 10) || 20;
    var people    = 1;

    function paintTotal() {
        peopleVal.textContent = people;
        totalEl.textContent = '$' + (perPerson * people).toLocaleString('en-US');
    }
    paintTotal();

    document.getElementById('people-inc').addEventListener('click', function() {
        if (people < Math.min(maxSeats, 20)) { people++; paintTotal(); }
    });
    document.getElementById('people-dec').addEventListener('click', function() {
        if (people > 1) { people--; paintTotal(); }
    });

    function showMsg(text, kind) {
        msgEl.textContent = text;
        msgEl.className = 'tg-book-msg tg-book-msg-' + (kind || 'info');
        msgEl.style.display = 'block';
    }

    // ── Book button — async, token fetched fresh, inline errors ──
    bookBtn.addEventListener('click', async function() {
        msgEl.style.display = 'none';

        var freshToken = localStorage.getItem('travlr-token');
        if (!freshToken) {
            showMsg('Please sign in to reserve this trip. Redirecting…', 'warn');
            setTimeout(function() { window.location.href = '/login'; }, 900);
            return;
        }

        // Token expiry sanity check so a stale token doesn't get a confusing 401.
        try {
            var payload = JSON.parse(atob(freshToken.split('.')[1]));
            if (!payload.exp || payload.exp <= Math.floor(Date.now() / 1000)) {
                localStorage.removeItem('travlr-token');
                showMsg('Your session has expired. Please sign in again.', 'warn');
                setTimeout(function() { window.location.href = '/login'; }, 900);
                return;
            }
        } catch (_) {
            localStorage.removeItem('travlr-token');
            showMsg('Invalid session. Please sign in again.', 'warn');
            setTimeout(function() { window.location.href = '/login'; }, 900);
            return;
        }

        bookBtn.disabled = true;
        var originalText = bookBtn.innerHTML;
        bookBtn.innerHTML = 'Booking&hellip;';

        try {
            var r = await fetch('/api/reservations', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Accept': 'application/json',
                    'Authorization': 'Bearer ' + freshToken
                },
                body: JSON.stringify({ tripCode: tripCode, people: people })
            });
            var raw = await r.text();
            var d = {}; try { d = raw ? JSON.parse(raw) : {}; } catch (_) {}

            if (r.ok) {
                showMsg('Reserved! Redirecting to your trips…', 'ok');
                setTimeout(function() { window.location.href = '/reservations'; }, 700);
            } else if (r.status === 401) {
                localStorage.removeItem('travlr-token');
                showMsg('Your session expired. Please sign in again.', 'warn');
                setTimeout(function() { window.location.href = '/login'; }, 900);
            } else {
                showMsg(d.message || ('Could not book this trip (HTTP ' + r.status + ').'), 'err');
                bookBtn.disabled = false;
                bookBtn.innerHTML = originalText;
            }
        } catch (err) {
            showMsg('Network error: ' + (err && err.message ? err.message : 'request failed'), 'err');
            bookBtn.disabled = false;
            bookBtn.innerHTML = originalText;
        }
    });
})();
</script>

{{> footer}}
