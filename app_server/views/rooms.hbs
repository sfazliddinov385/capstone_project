{{> header}}

<!-- Hero header -->
<div class="tg-rooms-hero">
    <div class="tg-rooms-hero-inner">
        <span class="tg-hero-eyebrow">Accommodations</span>
        <h1>Stay in <em>Comfort</em>, Wake in Paradise</h1>
        <p>Three thoughtfully designed room categories, from a cozy retreat to an oceanfront suite. Every stay includes resort access, daily housekeeping, and complimentary Wi-Fi.</p>
    </div>
</div>

<section class="tg-section tg-section-gray">
    <div class="tg-section-wrap">
        <div class="tg-rooms-grid">

            <article class="tg-room-card">
                <div class="tg-room-img">
                    <img src="/images/first-class.jpg" alt="First Class Room" loading="lazy">
                    <span class="tg-room-badge tg-room-badge-luxury">&#10024; Signature</span>
                </div>
                <div class="tg-room-body">
                    <div class="tg-room-eyebrow">Top Tier</div>
                    <h2 class="tg-room-title">First Class Room</h2>
                    <p class="tg-room-desc">A private spa-style retreat. A king bed dressed in premium linens, a freestanding soaking tub set right in the room, and a working stone fireplace flanked by velvet lounge chairs. Floor-to-ceiling windows frame the skyline at dusk.</p>
                    <ul class="tg-room-features">
                        <li>&#128719; King bed &middot; sleeps 2</li>
                        <li>&#128705; Freestanding soaking tub</li>
                        <li>&#128293; Working stone fireplace</li>
                        <li>&#127769; Skyline view at sunset</li>
                    </ul>
                    <div class="tg-room-footer">
                        <div class="tg-room-price">
                            <span class="tg-price-amount">$220</span>
                            <span class="tg-price-per">/ night</span>
                        </div>
                        <a href="/travel" class="btn-room-book">Reserve &rarr;</a>
                    </div>
                </div>
            </article>

            <article class="tg-room-card">
                <div class="tg-room-img">
                    <img src="/images/suite.jpg" alt="Suite Room" loading="lazy">
                    <span class="tg-room-badge tg-room-badge-suite">&#11088; Most Popular</span>
                </div>
                <div class="tg-room-body">
                    <div class="tg-room-eyebrow">Best Value</div>
                    <h2 class="tg-room-title">Suite Room</h2>
                    <p class="tg-room-desc">A formal parlor with a crystal chandelier overhead, a private dining alcove set for evening, and floor-to-ceiling windows opening to a bay view at twilight. A rotating curated art collection completes the salon feel.</p>
                    <ul class="tg-room-features">
                        <li>&#10024; Crystal chandelier parlor</li>
                        <li>&#127869;&#65039; Private dining alcove</li>
                        <li>&#127754; Floor-to-ceiling bay view</li>
                        <li>&#128444;&#65039; Curated art collection</li>
                    </ul>
                    <div class="tg-room-footer">
                        <div class="tg-room-price">
                            <span class="tg-price-amount">$180</span>
                            <span class="tg-price-per">/ night</span>
                        </div>
                        <a href="/travel" class="btn-room-book">Reserve &rarr;</a>
                    </div>
                </div>
            </article>

            <article class="tg-room-card">
                <div class="tg-room-img">
                    <img src="/images/deluxe.jpg" alt="Deluxe Room" loading="lazy">
                    <span class="tg-room-badge tg-room-badge-deluxe">&#127963;&#65039; Classic</span>
                </div>
                <div class="tg-room-body">
                    <div class="tg-room-eyebrow">Heritage</div>
                    <h2 class="tg-room-title">Deluxe Room</h2>
                    <p class="tg-room-desc">Step into a heritage library lounge. A hand-carved plasterwork ceiling, crimson velvet seating around a marble fireplace, period windows that frame the historic facades next door, and a backgammon table set for after-dinner play.</p>
                    <ul class="tg-room-features">
                        <li>&#128218; Heritage library lounge</li>
                        <li>&#127884; Ornate plaster ceiling</li>
                        <li>&#9823;&#65039; Backgammon game table</li>
                        <li>&#127981; Period arch windows</li>
                    </ul>
                    <div class="tg-room-footer">
                        <div class="tg-room-price">
                            <span class="tg-price-amount">$150</span>
                            <span class="tg-price-per">/ night</span>
                        </div>
                        <a href="/travel" class="btn-room-book">Reserve &rarr;</a>
                    </div>
                </div>
            </article>

        </div>

        <!-- What's always included strip -->
        <div class="tg-room-included-strip">
            <h3>Every room includes</h3>
            <div class="tg-included-grid">
                <div class="tg-included-item">
                    <div class="tg-included-icon">&#129529;</div>
                    <div class="tg-included-label">Daily housekeeping</div>
                </div>
                <div class="tg-included-item">
                    <div class="tg-included-icon">&#128246;</div>
                    <div class="tg-included-label">High-speed Wi-Fi</div>
                </div>
                <div class="tg-included-item">
                    <div class="tg-included-icon">&#129360;</div>
                    <div class="tg-included-label">Complimentary breakfast</div>
                </div>
                <div class="tg-included-item">
                    <div class="tg-included-icon">&#9832;&#65039;</div>
                    <div class="tg-included-label">Pool &amp; spa access</div>
                </div>
                <div class="tg-included-item">
                    <div class="tg-included-icon">&#127965;&#65039;</div>
                    <div class="tg-included-label">Private beach</div>
                </div>
                <div class="tg-included-item">
                    <div class="tg-included-icon">&#128718;&#65039;</div>
                    <div class="tg-included-label">24/7 concierge</div>
                </div>
            </div>
        </div>

    </div>
</section>

{{> footer}}
