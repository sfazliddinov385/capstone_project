{{> header}}

<!-- Reading progress bar -->
<div class="tg-art-progress" aria-hidden="true"><div class="tg-art-progress-fill" id="tg-art-progress-fill"></div></div>

<!-- Breadcrumb -->
<nav aria-label="Breadcrumb" class="tg-crumb">
    <div class="tg-crumb-wrap">
        <a href="/">Home</a>
        <span aria-hidden="true">&rsaquo;</span>
        <a href="/news">Journal</a>
        <span aria-hidden="true">&rsaquo;</span>
        <span aria-current="page">{{article.title}}</span>
    </div>
</nav>

<!-- ══════════════════════════════════════════════════════
     ARTICLE HERO (immersive photo with dark gradient)
     ══════════════════════════════════════════════════════ -->
<section class="tg-art-hero" style="background-image: linear-gradient(180deg, rgba(8,32,56,0.10) 0%, rgba(8,32,56,0.45) 50%, rgba(8,32,56,0.95) 100%), url('{{article.image}}');">
    <div class="tg-art-hero-inner">
        <span class="tg-nw-tag tg-nw-tag-{{article.category}} tg-art-hero-tag">{{article.category}}</span>
        <h1>{{article.title}}</h1>
        <p class="tg-art-hero-deck">{{article.excerpt}}</p>
        <div class="tg-art-meta">
            <span class="tg-nw-meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                {{article.date}}
            </span>
            <span class="tg-nw-meta-dot" aria-hidden="true"></span>
            <span class="tg-nw-meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                By {{article.author}}
            </span>
            <span class="tg-nw-meta-dot" aria-hidden="true"></span>
            <span class="tg-nw-meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                {{article.readMin}} min read
            </span>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════
     ARTICLE BODY + SIDEBAR
     ══════════════════════════════════════════════════════ -->
<section class="tg-art-body">
    <div class="tg-art-wrap">

        <article class="tg-art-content" id="tg-art-content">
            {{#each article.body}}
                <p>{{this}}</p>
            {{/each}}

            <!-- Share row -->
            <div class="tg-art-share">
                <span class="tg-art-share-label">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                    Share this story
                </span>
                <div class="tg-art-share-btns">
                    <button type="button" class="tg-share-btn" data-share="twitter" aria-label="Share on X">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                    </button>
                    <button type="button" class="tg-share-btn" data-share="facebook" aria-label="Share on Facebook">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
                    </button>
                    <button type="button" class="tg-share-btn" data-share="linkedin" aria-label="Share on LinkedIn">
                        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 110-4.124 2.062 2.062 0 010 4.124zm1.778 13.019H3.555V9h3.56v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451c.979 0 1.778-.773 1.778-1.729V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    </button>
                    <button type="button" class="tg-share-btn" data-share="link" aria-label="Copy link">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                    </button>
                </div>
            </div>

            <!-- Author block -->
            <div class="tg-art-author">
                <div class="tg-art-author-avatar">{{article.author}}</div>
                <div class="tg-art-author-meta">
                    <div class="tg-art-author-name">{{article.author}}</div>
                    <div class="tg-art-author-role">Travlr Contributor</div>
                    <p class="tg-art-author-bio">A member of the Travlr editorial team covering destinations, adventure, and travel culture.</p>
                </div>
            </div>

            <a href="/news" class="tg-art-back">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                Back to the journal
            </a>
        </article>

        <!-- Sidebar -->
        <aside class="tg-art-aside">
            <div class="tg-art-aside-card">
                <h3>Keep reading</h3>
                {{#each related}}
                    <a href="/news/{{slug}}" class="tg-related-item">
                        <div class="tg-related-thumb">
                            <img src="{{image}}" alt="" loading="lazy" onerror="this.src='/images/sea-sound.jpg'">
                        </div>
                        <div class="tg-related-body">
                            <div class="tg-related-cat">{{category}}</div>
                            <div class="tg-related-title">{{title}}</div>
                            <div class="tg-related-meta">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                                {{readMin}} min · {{date}}
                            </div>
                        </div>
                    </a>
                {{/each}}
            </div>

            <div class="tg-art-aside-card tg-art-cta">
                <div class="tg-art-cta-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <h4>Plan your trip</h4>
                <p>Browse 15 all-inclusive packages, hand-picked by our team.</p>
                <a href="/travel" class="btn-primary btn-primary-pro">
                    View trips
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
            </div>
        </aside>

    </div>
</section>

<script>
(function() {
    /* ── Share buttons ────────────────────────────────────────── */
    document.querySelectorAll('.tg-share-btn').forEach(function(btn) {
        btn.addEventListener('click', async function() {
            var kind = btn.getAttribute('data-share');
            var url   = window.location.href;
            var title = document.title;
            if (kind === 'twitter') {
                window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(title) + '&url=' + encodeURIComponent(url), '_blank', 'noopener');
            } else if (kind === 'facebook') {
                window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url), '_blank', 'noopener');
            } else if (kind === 'linkedin') {
                window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(url), '_blank', 'noopener');
            } else if (kind === 'link') {
                try {
                    await navigator.clipboard.writeText(url);
                    var orig = btn.innerHTML;
                    btn.innerHTML = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
                    if (window.tgToast) window.tgToast('Link copied to clipboard.', 'success');
                    setTimeout(function() { btn.innerHTML = orig; }, 1600);
                } catch(e) {}
            }
        });
    });

    /* ── Author avatar initial ────────────────────────────────── */
    var avatarEl = document.querySelector('.tg-art-author-avatar');
    if (avatarEl) {
        var name = avatarEl.textContent.trim();
        var parts = name.split(/\s+/);
        avatarEl.textContent = ((parts[0]||'')[0] + (parts[1]||'')[0]).toUpperCase();
    }

    /* ── Reading progress bar ─────────────────────────────────── */
    var bar = document.getElementById('tg-art-progress-fill');
    var article = document.getElementById('tg-art-content');
    if (bar && article) {
        var ticking = false;
        function update() {
            ticking = false;
            var rect = article.getBoundingClientRect();
            var top  = rect.top + window.scrollY;
            var h    = article.offsetHeight;
            var winH = window.innerHeight;
            var scrolled = Math.max(0, window.scrollY - top + winH * 0.25);
            var range    = h - winH * 0.5;
            var p = range > 0 ? Math.min(1, Math.max(0, scrolled / range)) : 0;
            bar.style.width = (p * 100).toFixed(2) + '%';
        }
        window.addEventListener('scroll', function() {
            if (!ticking) { ticking = true; requestAnimationFrame(update); }
        }, { passive: true });
        window.addEventListener('resize', update, { passive: true });
        update();
    }
})();
</script>

{{> footer}}
