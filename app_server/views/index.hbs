<!-- ══════════════════════════════════════════════════════
     INLINE BEHAVIORS — parallax, count-up, newsletter
     ══════════════════════════════════════════════════════ -->
<script>
(function() {
    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ── Count-up stats ─────────────────────────────────────── */
    function formatNum(n, suffix, format) {
        if (format === 'k') {
            var k = Math.round(n / 100) / 10;
            return (k % 1 === 0 ? k.toFixed(0) : k.toFixed(1)) + 'K' + (suffix || '');
        }
        return Math.round(n).toLocaleString() + (suffix || '');
    }
    function animateCount(el) {
        var target = parseFloat(el.getAttribute('data-count')) || 0;
        var suffix = el.getAttribute('data-suffix') || '';
        var format = el.getAttribute('data-format') || '';
        if (reduceMotion) { el.textContent = formatNum(target, suffix, format); return; }
        var start = performance.now();
        var dur = 1400;
        function tick(now) {
            var p = Math.min(1, (now - start) / dur);
            var eased = 1 - Math.pow(1 - p, 3);
            el.textContent = formatNum(target * eased, suffix, format);
            if (p < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
    }
    if ('IntersectionObserver' in window) {
        var statsEl = document.getElementById('tg-stats');
        if (statsEl) {
            var seen = false;
            var io = new IntersectionObserver(function(entries) {
                entries.forEach(function(e) {
                    if (e.isIntersecting && !seen) {
                        seen = true;
                        statsEl.querySelectorAll('.tg-stat-number[data-count]').forEach(animateCount);
                        io.disconnect();
                    }
                });
            }, { threshold: 0.4 });
            io.observe(statsEl);
        }
    } else {
        document.querySelectorAll('.tg-stat-number[data-count]').forEach(animateCount);
    }

    /* ── Hero photo parallax (mouse) ─────────────────────────── */
    if (!reduceMotion) {
        var photosWrap = document.getElementById('tg-hero-photos');
        if (photosWrap) {
            var els = photosWrap.querySelectorAll('[data-parallax]');
            var rect = null;
            var raf = null;
            var mx = 0, my = 0;
            function update() {
                raf = null;
                if (!rect) rect = photosWrap.getBoundingClientRect();
                var dx = (mx - rect.left - rect.width  / 2) / rect.width;
                var dy = (my - rect.top  - rect.height / 2) / rect.height;
                els.forEach(function(el) {
                    var s = parseFloat(el.getAttribute('data-parallax')) || 0.02;
                    el.style.transform = 'translate3d(' + (dx * s * 60).toFixed(2) + 'px, ' + (dy * s * 60).toFixed(2) + 'px, 0)';
                });
            }
            photosWrap.addEventListener('mousemove', function(e) {
                mx = e.clientX; my = e.clientY;
                if (!raf) raf = requestAnimationFrame(update);
            });
            photosWrap.addEventListener('mouseleave', function() {
                els.forEach(function(el) { el.style.transform = ''; });
                rect = null;
            });
            window.addEventListener('resize', function() { rect = null; }, { passive: true });
        }
    }

    /* ── Newsletter submit ───────────────────────────────────── */
    window.tgNewsletterSubmit = function() {
        var input = document.getElementById('tg-newsletter-email');
        var email = input && input.value.trim();
        if (!email) return;
        try { localStorage.setItem('travlr-newsletter', email); } catch (e) {}
        if (input) input.value = '';
        if (window.tgToast) window.tgToast('Thanks! Watch your inbox for the next drop.', 'success');
    };
})();
</script>

