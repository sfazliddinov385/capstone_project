{{> header}}

<!-- ══════════════════════════════════════════════════════
     HERO — split layout, photo collage, animated mesh
     ══════════════════════════════════════════════════════ -->
<section class="tg-hero tg-hero-v2">
    <div class="tg-hero-bg">
        <div class="tg-hero-blob tg-hero-blob-1"></div>
        <div class="tg-hero-blob tg-hero-blob-2"></div>
        <div class="tg-hero-blob tg-hero-blob-3"></div>
        <div class="tg-hero-noise" aria-hidden="true"></div>
    </div>

    <div class="tg-hero-inner">

        <!-- ── LEFT: copy + search ── -->
        <div class="tg-hero-left">
            <div class="tg-hero-eyebrow">
                <span class="tg-eyebrow-dot"></span>
                World-class travel experiences
            </div>

            <h1 class="tg-hero-title-anim">
                Where will your<br>
                <em data-shimmer>next adventure</em><br>
                begin?
            </h1>

            <p class="tg-hero-sub">
                Handpicked destinations, all-inclusive packages, and 24/7 concierge support.
                Everything you need for an unforgettable journey.
            </p>

            <form class="tg-hero-search tg-hero-search-pro"
                  onsubmit="event.preventDefault(); window.location.href='/travel?q='+encodeURIComponent(document.getElementById('hero-search').value);">
                <div class="tg-hero-search-field">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <input type="text" id="hero-search" placeholder="Where to? Bali, Maldives, Seychelles…" autocomplete="off" aria-label="Search destinations">
                </div>
                <button type="submit" class="tg-hero-search-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.5-4.5"/></svg>
                    Search
                </button>
            </form>

            <!-- Quick-pick category chips -->
            <div class="tg-hero-chips" role="list" aria-label="Popular categories">
                <a href="/travel?q=beach"     class="tg-hero-chip" role="listitem"><span aria-hidden="true">&#127958;</span> Beach</a>
                <a href="/travel?q=mountain"  class="tg-hero-chip" role="listitem"><span aria-hidden="true">&#127956;</span> Mountain</a>
                <a href="/travel?q=city"      class="tg-hero-chip" role="listitem"><span aria-hidden="true">&#127961;</span> City</a>
                <a href="/travel?q=adventure" class="tg-hero-chip" role="listitem"><span aria-hidden="true">&#129518;</span> Adventure</a>
                <a href="/travel?q=culture"   class="tg-hero-chip" role="listitem"><span aria-hidden="true">&#127914;</span> Culture</a>
            </div>

            <div class="tg-hero-cta-row">
                <a href="/travel" class="btn-primary btn-primary-pro">
                    Explore Trips
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
                <a href="/register" class="btn-outline btn-outline-pro">Create Free Account</a>
            </div>

            <div class="tg-hero-trust">
                <div class="tg-trust-item">
                    <div class="tg-trust-num">4.9 <span style="color:#e8b84b;">&#9733;</span></div>
                    <div class="tg-trust-label">From 2,300 reviews</div>
                </div>
                <div class="tg-trust-divider"></div>
                <div class="tg-trust-item">
                    <div class="tg-trust-num">12k+</div>
                    <div class="tg-trust-label">Happy travelers</div>
                </div>
                <div class="tg-trust-divider"></div>
                <div class="tg-trust-item">
                    <div class="tg-trust-num">50+</div>
                    <div class="tg-trust-label">Destinations</div>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: photo collage (3D tilt parallax) ── -->
        <div class="tg-hero-right">
            <div class="tg-hero-photos" id="tg-hero-photos">
                <div class="tg-photo tg-photo-main" data-parallax="0.025">
                    <img src="/images/tropical-lagoon.jpg" alt="Tropical lagoon">
                    <div class="tg-photo-meta">
                        <div class="tg-photo-pin">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                            Maldives
                        </div>
                        <div class="tg-photo-title">Crystal Lagoon Retreat</div>
                    </div>
                    <span class="tg-photo-corner" aria-hidden="true"></span>
                </div>

                <div class="tg-photo tg-photo-side tg-photo-side-1" data-parallax="0.04">
                    <img src="/images/swiss-alps.jpg" alt="Swiss Alps">
                    <div class="tg-photo-tag">Swiss Alps</div>
                </div>

                <div class="tg-photo tg-photo-side tg-photo-side-2" data-parallax="0.035">
                    <img src="/images/seychelles.jpg" alt="Seychelles">
                    <div class="tg-photo-tag">Seychelles</div>
                </div>

                <!-- Floating rating card -->
                <div class="tg-hero-float" data-parallax="0.06">
                    <div class="tg-hero-float-icon">
                        <svg viewBox="0 0 24 24" fill="#e8b84b" stroke="#e8b84b" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    </div>
                    <div>
                        <div class="tg-hero-float-num">4.9 / 5</div>
                        <div class="tg-hero-float-label">Traveler rating</div>
                    </div>
                </div>

                <!-- Floating destination count -->
                <div class="tg-hero-float-2" data-parallax="0.05">
                    <div class="tg-hero-float-bars">
                        <span></span><span></span><span></span><span></span>
                    </div>
                    <div>
                        <div class="tg-hero-float-num">98%</div>
                        <div class="tg-hero-float-label">Would book again</div>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- Scroll cue -->
    <a href="#tg-trust-strip" class="tg-hero-scroll-cue" aria-label="Scroll down">
        <span class="tg-scroll-mouse"><span class="tg-scroll-dot"></span></span>
        <span class="tg-scroll-label">Discover more</span>
    </a>
</section>

<!-- ══════════════════════════════════════════════════════
     TRUST STRIP — partner / press logos marquee
     ══════════════════════════════════════════════════════ -->
<section class="tg-trust-strip" id="tg-trust-strip" aria-label="Featured in">
    <div class="tg-trust-strip-inner">
        <div class="tg-trust-strip-label">As featured in</div>
        <div class="tg-marquee" aria-hidden="true">
            <div class="tg-marquee-track">
                <span>Conde Nast Traveler</span>
                <span>National Geographic</span>
                <span>Travel + Leisure</span>
                <span>Forbes</span>
                <span>The New York Times</span>
                <span>Lonely Planet</span>
                <span>Bloomberg</span>
                <span>Conde Nast Traveler</span>
                <span>National Geographic</span>
                <span>Travel + Leisure</span>
                <span>Forbes</span>
                <span>The New York Times</span>
                <span>Lonely Planet</span>
                <span>Bloomberg</span>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════════════════
     STATS with count-up animation
     ══════════════════════════════════════════════════════ -->
<div class="tg-stats tg-stats-v2 tg-fade-in" id="tg-stats">
    <div class="tg-stats-inner">
        <div class="tg-stat">
            <span class="tg-stat-number" data-count="50" data-suffix="+">0</span>
            <span class="tg-stat-label">Destinations</span>
        </div>
        <div class="tg-stat">
            <span class="tg-stat-number" data-count="12000" data-suffix="+" data-format="k">0</span>
            <span class="tg-stat-label">Happy Travelers</span>
        </div>
        <div class="tg-stat">
            <span class="tg-stat-number" data-count="98" data-suffix="%">0</span>
            <span class="tg-stat-label">Satisfaction Rate</span>
        </div>
        <div class="tg-stat">
            <span class="tg-stat-number" data-count="15" data-suffix="+">0</span>
            <span class="tg-stat-label">Years of Experience</span>
        </div>
    </div>
</div>

