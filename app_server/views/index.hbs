<!-- ══════════════════════════════════════════════════════
     FEATURED DESTINATIONS
     ══════════════════════════════════════════════════════ -->
<section class="tg-section tg-section-gray">
    <div class="tg-section-wrap">
        <div class="tg-section-head tg-fade-in">
            <div class="tg-section-label">Popular Right Now</div>
            <h2 class="tg-section-title">Trending Destinations</h2>
            <p class="tg-section-sub">Our most-booked escapes, loved by travelers just like you.</p>
        </div>
        <div class="tg-grid">
            {{#each featuredTrips}}
            <div class="tg-card tg-card-pro tg-fade-in">
                <div class="tg-card-img">
                    <img src="{{image}}" alt="{{name}}" loading="lazy" onerror="this.src='/images/sea-sound.jpg'">
                    <span class="tg-card-badge">&#128293; Featured</span>
                    <span class="tg-card-overlay" aria-hidden="true"></span>
                </div>
                <div class="tg-card-body">
                    <div class="tg-card-resort">&#128205; {{resort}}</div>
                    <div class="tg-card-title">{{name}}</div>
                    <p class="tg-card-desc">{{description}}</p>
                    <div class="tg-card-meta">
                        <span class="tg-card-meta-item">&#128197; {{length}}</span>
                        <span class="tg-card-meta-item">&#127968; {{resort}}</span>
                    </div>
                    <div class="tg-card-price">
                        <span class="tg-price-from">from</span>
                        <span class="tg-price-amount">${{perPerson}}</span>
                        <span class="tg-price-per">/ person</span>
                    </div>
                    <a href="/travel?q={{code}}" class="btn-add-cart" style="display:inline-block; text-align:center;">View Trip &rarr;</a>
                </div>
            </div>
            {{/each}}
            {{#if noFeaturedTrips}}
            <div class="tg-empty-state" style="grid-column:1/-1; text-align:center; padding:48px 16px; color:#5a5a5a;">
                <p style="font-size:18px; margin-bottom:12px;">No featured trips yet.</p>
                <p style="margin-bottom:20px;">New escapes are added every week. Browse the full catalog while we curate the next batch.</p>
                <a href="/travel" class="btn-primary">Browse all trips</a>
            </div>
            {{/if}}
        </div>
        <div style="text-align:center; margin-top:40px;">
            <a href="/travel" class="btn-primary btn-primary-pro">
                View All Trips
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
            </a>
        </div>
    </div>
</section>

