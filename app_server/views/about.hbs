{{> header}}

<!-- Hero -->
<div class="tg-about-hero">
    <div class="tg-about-hero-inner">
        <span class="tg-hero-eyebrow">Our Story</span>
        <h1>We craft the trips you&rsquo;ll <em>remember forever</em>.</h1>
        <p>Travlr Getaways began with a simple idea: that travel should feel curated, not catalogued. For over a decade, we&rsquo;ve been designing trips that match how real travelers actually want to explore the world.</p>
    </div>
</div>

<!-- Story split -->
<section class="tg-section tg-section-gray">
    <div class="tg-section-wrap">
        <div class="tg-about-split">
            <div class="tg-about-split-text">
                <span class="tg-about-eyebrow">Founded 2014</span>
                <h2>Built by travelers, for travelers</h2>
                <p>We started as a group of friends who kept piecing together our own itineraries because the cookie-cutter packages out there never quite fit. Eight people became a team of forty across three continents, but the original idea hasn&rsquo;t changed: every Travlr Getaways trip is hand-picked, locally verified, and priced honestly. All-inclusive means all-inclusive.</p>
                <p>Today we partner with over 200 boutique resorts, local guides, and dive operators in 38 countries. We do not sell anywhere we haven&rsquo;t personally visited.</p>
                <div class="tg-about-cta-row">
                    <a href="/travel" class="btn-about-primary">Browse trips &rarr;</a>
                    <a href="/contact" class="btn-about-secondary">Talk to us</a>
                </div>
            </div>
            <div class="tg-about-split-img">
                <img src="/images/reef2.jpg" alt="On location with a Travlr Getaways guide" loading="lazy">
                <div class="tg-about-img-tag">
                    <strong>Palau &middot; 2024</strong>
                    <span>Field-checking a new dive itinerary</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats -->
<section class="tg-about-stats">
    <div class="tg-section-wrap">
        <div class="tg-stats-grid">
            <div class="tg-stat">
                <div class="tg-stat-num">12k+</div>
                <div class="tg-stat-label">Travelers hosted</div>
            </div>
            <div class="tg-stat">
                <div class="tg-stat-num">38</div>
                <div class="tg-stat-label">Countries on the map</div>
            </div>
            <div class="tg-stat">
                <div class="tg-stat-num">4.9&#9733;</div>
                <div class="tg-stat-label">Average trip rating</div>
            </div>
            <div class="tg-stat">
                <div class="tg-stat-num">10+</div>
                <div class="tg-stat-label">Years on the ground</div>
            </div>
        </div>
    </div>
</section>

<!-- Values -->
<section class="tg-section">
    <div class="tg-section-wrap">
        <div class="tg-section-head">
            <span class="tg-about-eyebrow">What we stand for</span>
            <h2>The four things we never compromise on</h2>
            <p class="tg-section-sub">Every package, every partner, every booking flows through the same four filters.</p>
        </div>

        <div class="tg-values-grid">
            <article class="tg-value-card">
                <div class="tg-value-icon">&#127757;</div>
                <h3>Curated, not catalogued</h3>
                <p>Every itinerary is personally vetted by a team member who has been there. No drop-shipped trips, no white-labeled tours.</p>
            </article>
            <article class="tg-value-card">
                <div class="tg-value-icon">&#129309;</div>
                <h3>Local-first partnerships</h3>
                <p>We work with family-run resorts and certified local guides. A bigger share of what you pay stays where you visit.</p>
            </article>
            <article class="tg-value-card">
                <div class="tg-value-icon">&#127807;</div>
                <h3>Honestly sustainable</h3>
                <p>We measure our carbon footprint per trip and offset it. We disclose our suppliers&rsquo; sustainability ratings on every listing.</p>
            </article>
            <article class="tg-value-card">
                <div class="tg-value-icon">&#128241;</div>
                <h3>24/7 traveler support</h3>
                <p>From the moment you book until you&rsquo;re home, a real human is one message away in your timezone. Not a chatbot.</p>
            </article>
        </div>
    </div>
</section>

<!-- Team -->
<section class="tg-section tg-section-gray">
    <div class="tg-section-wrap">
        <div class="tg-section-head">
            <span class="tg-about-eyebrow">The team</span>
            <h2>Meet the people behind your next trip</h2>
            <p class="tg-section-sub">Forty travelers, dive-masters, chefs, and itinerary nerds across three continents.</p>
        </div>

        <div class="tg-team-grid">
            <div class="tg-team-card">
                <div class="tg-team-avatar" style="background: linear-gradient(135deg,#0a4a78,#0c5a90);">SF</div>
                <h4>Sarvarbek Fazliddinov</h4>
                <div class="tg-team-role">Founder &amp; CEO</div>
                <p>Founded Travlr Getaways with the belief that great trips start with great software.</p>
            </div>
            <div class="tg-team-card">
                <div class="tg-team-avatar" style="background: linear-gradient(135deg,#c79b3d,#e8b84b); color:#2c1a00;">RK</div>
                <h4>Ravi Kapoor</h4>
                <div class="tg-team-role">Head of Itinerary Design</div>
                <p>Walked the entire Camino de Santiago twice. Knows every train timetable in Europe.</p>
            </div>
            <div class="tg-team-card">
                <div class="tg-team-avatar" style="background: linear-gradient(135deg,#155e75,#0e7490);">AC</div>
                <h4>Ana Cruz</h4>
                <div class="tg-team-role">Director of Partnerships</div>
                <p>Negotiates the small-resort deals that keep our prices honest. Speaks five languages.</p>
            </div>
            <div class="tg-team-card">
                <div class="tg-team-avatar" style="background: linear-gradient(135deg,#4f46e5,#6366f1);">JT</div>
                <h4>Jordan Tate</h4>
                <div class="tg-team-role">24/7 Traveler Support</div>
                <p>Leads our concierge desk. The voice on the other end of every &ldquo;help, we&rsquo;re stuck at customs&rdquo;.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="tg-about-cta">
    <div class="tg-section-wrap">
        <div class="tg-about-cta-inner">
            <h2>Ready to find your next trip?</h2>
            <p>Twelve hand-picked getaways on the catalog right now, from a four-day reef dive in Palau to a slow-pace cultural circuit through Kyoto.</p>
            <div class="tg-about-cta-row" style="justify-content:center;">
                <a href="/travel" class="btn-about-primary">Explore all trips &rarr;</a>
                <a href="/contact" class="btn-about-secondary btn-about-secondary-light">Plan something custom</a>
            </div>
        </div>
    </div>
</section>

{{> footer}}
