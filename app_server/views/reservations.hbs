{{> header}}

<!-- ══════════════════════════════════════════════════════
     HERO
     ══════════════════════════════════════════════════════ -->
<section class="tg-res-hero">
    <div class="tg-res-hero-bg" aria-hidden="true">
        <div class="tg-travel-blob tg-travel-blob-1"></div>
        <div class="tg-travel-blob tg-travel-blob-2"></div>
        <div class="tg-travel-blob tg-travel-blob-3"></div>
        <div class="tg-travel-grid-overlay"></div>
    </div>
    <div class="tg-res-hero-inner">
        <div class="tg-travel-hero-eyebrow">
            <span class="tg-eyebrow-dot"></span>
            <span id="hero-sub-eyebrow">Your travel calendar</span>
        </div>
        <h1 class="tg-travel-hero-title">
            <span id="hero-name-block">My <em data-shimmer>Reservations</em></span>
        </h1>
        <p class="tg-travel-hero-sub" id="hero-sub-text">
            View, manage, and reflect on every journey you've booked with Travlr.
        </p>
    </div>
</section>

<section class="tg-section tg-section-gray tg-res-section">
    <div class="tg-section-wrap">

        <!-- ── GUEST GATE (shown when not signed in) ────────────── -->
        <div id="guest-message" style="display:none;">
            <div class="tg-res-gate tg-fade-in">
                <div class="tg-res-gate-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                </div>
                <h2>Sign in to see your trips</h2>
                <p>This page is for logged-in customers. Sign in with your Travlr account to view, manage, and review your reservations.</p>
                <div class="tg-res-gate-actions">
                    <a href="/login" class="btn-primary btn-primary-pro">
                        Sign in
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                    </a>
                    <a href="/register" class="btn-outline btn-outline-pro">Create account</a>
                </div>
            </div>
        </div>

        <!-- ── LOGGED-IN CONTENT ────────────────────────────────── -->
        <div id="reservations-content" style="display:none;">

            <!-- Action toolbar -->
            <div class="tg-res-toolbar">
                <div class="tg-res-toolbar-info">
                    <span class="tg-res-toolbar-label">Signed in as</span>
                    <span class="tg-res-toolbar-name" id="customer-name">—</span>
                </div>
                <div class="tg-res-toolbar-actions">
                    <a href="/travel" class="btn-primary btn-primary-pro">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12h14"/></svg>
                        Book new trip
                    </a>
                    <button id="logout-btn" type="button" class="tg-res-logout">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                        Sign out
                    </button>
                </div>
            </div>

            <!-- KPI strip -->
            <div class="tg-res-kpis">
                <div class="tg-res-kpi tg-res-kpi-blue tg-fade-in">
                    <div class="tg-res-kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    </div>
                    <div>
                        <div class="tg-res-kpi-num" id="kpi-total">0</div>
                        <div class="tg-res-kpi-label">Total Bookings</div>
                    </div>
                </div>
                <div class="tg-res-kpi tg-res-kpi-teal tg-fade-in">
                    <div class="tg-res-kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>
                    </div>
                    <div>
                        <div class="tg-res-kpi-num" id="kpi-upcoming">0</div>
                        <div class="tg-res-kpi-label">Upcoming</div>
                    </div>
                </div>
                <div class="tg-res-kpi tg-res-kpi-rose tg-fade-in">
                    <div class="tg-res-kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 12V8H4v4"/><path d="M4 12v6a2 2 0 002 2h12a2 2 0 002-2v-6"/><path d="M2 8h20l-2-4H4l-2 4z"/></svg>
                    </div>
                    <div>
                        <div class="tg-res-kpi-num" id="kpi-travelers">0</div>
                        <div class="tg-res-kpi-label">Travelers</div>
                    </div>
                </div>
                <div class="tg-res-kpi tg-res-kpi-gold tg-fade-in">
                    <div class="tg-res-kpi-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                    <div>
                        <div class="tg-res-kpi-num" id="kpi-total-spent">$0</div>
                        <div class="tg-res-kpi-label">Total Spent</div>
                    </div>
                </div>
            </div>

            <!-- Tabs + search -->
            <div class="tg-res-tabs-bar">
                <div class="tg-res-tabs" role="tablist" aria-label="Filter reservations">
                    <button class="tg-res-tab is-active" data-filter="all" role="tab" aria-selected="true">
                        All <span class="tg-res-tab-count" id="count-all">0</span>
                    </button>
                    <button class="tg-res-tab" data-filter="upcoming" role="tab" aria-selected="false">
                        Upcoming <span class="tg-res-tab-count" id="count-upcoming">0</span>
                    </button>
                    <button class="tg-res-tab" data-filter="past" role="tab" aria-selected="false">
                        Past <span class="tg-res-tab-count" id="count-past">0</span>
                    </button>
                </div>
                <div class="tg-res-search">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.5-4.5"/></svg>
                    <input id="res-search" type="text" placeholder="Search by trip name or resort…" autocomplete="off" aria-label="Search reservations">
                </div>
            </div>

            <!-- Toast / banner area -->
            <div id="cancel-message" class="tg-alert tg-alert-success" style="display:none;"></div>

            <!-- Reservation cards -->
            <div class="tg-res-grid" id="reservations-list">
                <!-- Loading skeleton -->
                <div class="tg-res-skeleton" id="res-skeleton">
                    <div class="tg-res-card-skel"></div>
                    <div class="tg-res-card-skel"></div>
                    <div class="tg-res-card-skel"></div>
                </div>
            </div>

            <!-- Empty state (no reservations) -->
            <div id="res-empty" class="tg-empty-state tg-res-empty" style="display:none;">
                <div class="tg-empty-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <h3>No reservations yet</h3>
                <p>When you book a trip it will appear here. Ready for your next adventure?</p>
                <a href="/travel" class="btn-primary btn-primary-pro">
                    Browse trips
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
            </div>

            <!-- No-match state (filtered out) -->
            <div id="res-no-match" class="tg-empty-state tg-res-empty" style="display:none;">
                <div class="tg-empty-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.5-4.5"/></svg>
                </div>
                <h3>No matches</h3>
                <p>No reservations match the current filter. Try clearing your search or pick another tab.</p>
            </div>
        </div>

        <!-- ── REVIEW MODAL ─────────────────────────────────────── -->
        <div id="review-modal" class="tg-res-modal" role="dialog" aria-modal="true" aria-labelledby="review-modal-title">
            <div class="tg-res-modal-dialog">
                <div class="tg-res-modal-head">
                    <h3 id="review-modal-title">Leave a review</h3>
                    <button id="review-close" type="button" class="tg-res-modal-close" aria-label="Close review dialog">&times;</button>
                </div>
                <p class="tg-res-modal-sub">Reviewing <strong id="review-trip-name"></strong></p>

                <div id="review-error" class="tg-alert tg-alert-danger" style="display:none; margin-bottom:14px;"></div>

                <label class="tg-res-modal-label">Your rating</label>
                <div id="review-stars" class="tg-res-stars">
                    <button type="button" class="rev-star" data-v="1" aria-label="1 star">&#9733;</button>
                    <button type="button" class="rev-star" data-v="2" aria-label="2 stars">&#9733;</button>
                    <button type="button" class="rev-star" data-v="3" aria-label="3 stars">&#9733;</button>
                    <button type="button" class="rev-star" data-v="4" aria-label="4 stars">&#9733;</button>
                    <button type="button" class="rev-star" data-v="5" aria-label="5 stars">&#9733;</button>
                </div>

                <label class="tg-res-modal-label" for="review-comment">Your review</label>
                <textarea id="review-comment" rows="4" maxlength="1200" placeholder="Share what you loved and what could be better…"></textarea>
                <div class="tg-res-modal-count"><span id="review-count">0</span> / 1200</div>

                <div class="tg-res-modal-actions">
                    <button id="review-cancel" type="button" class="btn-outline btn-outline-pro">Cancel</button>
                    <button id="review-submit" type="button" class="btn-primary btn-primary-pro">Submit review</button>
                </div>
            </div>
        </div>

    </div>
</section>

<script>
(async function() {
    var token = localStorage.getItem('travlr-token');
    var isLoggedIn = false;
    var payload = null;

    if (token) {
        try {
            payload = JSON.parse(atob(token.split('.')[1]));
            isLoggedIn = payload.exp > Math.floor(Date.now() / 1000);
        } catch (e) { isLoggedIn = false; }
    }

    if (!isLoggedIn) {
        document.getElementById('guest-message').style.display = 'block';
        return;
    }

    document.getElementById('reservations-content').style.display = 'block';
    var displayName = payload.name || payload.email;
    var firstName = displayName.split(' ')[0] || displayName;
    document.getElementById('customer-name').textContent = displayName;
    document.getElementById('hero-name-block').innerHTML = 'Welcome back, <em data-shimmer>' + escapeHtml(firstName) + '</em>';
    document.getElementById('hero-sub-text').textContent = 'View, manage, and reflect on every journey you have booked with Travlr.';

    /* ── Util helpers ────────────────────────────────────────── */
    function escapeHtml(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }
    function money(n) {
        var v = parseFloat(n) || 0;
        return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }
    function fmtDate(d) {
        if (!d) return 'TBD';
        return new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }
    function daysFromNow(d) {
        if (!d) return null;
        var diff = new Date(d).getTime() - Date.now();
        return Math.round(diff / 86400000);
    }
    function destClass(name) {
        // Pick a deterministic gradient class from the trip name for variety
        var sum = 0;
        for (var i = 0; i < (name || '').length; i++) sum = (sum + name.charCodeAt(i)) % 6;
        return 'tg-res-dest-' + (sum + 1);
    }

    /* ── Fetch reservations ──────────────────────────────────── */
    var listEl = document.getElementById('reservations-list');
    var skeletonEl = document.getElementById('res-skeleton');
    var emptyEl = document.getElementById('res-empty');
    var noMatchEl = document.getElementById('res-no-match');
    var data = [];

    try {
        var res = await fetch('/api/reservations', { headers: { 'Authorization': 'Bearer ' + token } });
        data = (res.ok ? await res.json() : []) || [];
    } catch (err) {
        data = [];
    }

    if (skeletonEl) skeletonEl.remove();

    if (!data.length) {
        emptyEl.style.display = 'flex';
        updateKpis([]);
        updateTabCounts([]);
        return;
    }

    /* ── Render cards ─────────────────────────────────────────── */
    function renderCards(list) {
        listEl.innerHTML = '';
        if (!list.length) {
            noMatchEl.style.display = 'flex';
            return;
        }
        noMatchEl.style.display = 'none';

        list.forEach(function(r) {
            var dleft = daysFromNow(r.start);
            var statusLabel = '', statusKind = '';
            if (dleft === null)        { statusLabel = 'Date TBD';            statusKind = 'pending'; }
            else if (dleft > 30)       { statusLabel = 'In ' + dleft + ' days'; statusKind = 'upcoming'; }
            else if (dleft > 0)        { statusLabel = 'In ' + dleft + ' days'; statusKind = 'soon'; }
            else if (dleft === 0)      { statusLabel = 'Today!';                statusKind = 'soon'; }
            else                       { statusLabel = 'Completed';             statusKind = 'past'; }

            var card = document.createElement('article');
            card.className = 'tg-res-card tg-fade-in';
            card.setAttribute('data-id', r._id);
            card.setAttribute('data-status', dleft !== null && dleft < 0 ? 'past' : 'upcoming');

            card.innerHTML =
                '<div class="tg-res-card-banner ' + destClass(r.tripName) + '">' +
                    '<div class="tg-res-card-banner-overlay">' +
                        '<div class="tg-res-card-code">' + escapeHtml(r.tripCode || '') + '</div>' +
                        '<div class="tg-res-card-title">' + escapeHtml(r.tripName || 'Trip') + '</div>' +
                        '<div class="tg-res-card-resort"><span aria-hidden="true">&#128205;</span> ' + escapeHtml(r.resort || '—') + '</div>' +
                    '</div>' +
                    '<span class="tg-res-status tg-res-status-' + statusKind + '">' + statusLabel + '</span>' +
                '</div>' +
                '<div class="tg-res-card-body">' +
                    '<div class="tg-res-card-meta">' +
                        '<div class="tg-res-meta-item">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' +
                            '<div><span class="tg-res-meta-label">Start date</span><span class="tg-res-meta-val">' + fmtDate(r.start) + '</span></div>' +
                        '</div>' +
                        '<div class="tg-res-meta-item">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/></svg>' +
                            '<div><span class="tg-res-meta-label">Length</span><span class="tg-res-meta-val">' + escapeHtml(r.length || '—') + '</span></div>' +
                        '</div>' +
                        '<div class="tg-res-meta-item">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>' +
                            '<div><span class="tg-res-meta-label">Travelers</span><span class="tg-res-meta-val">' + (r.people || 1) + '</span></div>' +
                        '</div>' +
                        '<div class="tg-res-meta-item">' +
                            '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>' +
                            '<div><span class="tg-res-meta-label">Per person</span><span class="tg-res-meta-val">' + money(r.perPerson) + '</span></div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="tg-res-card-footer">' +
                        '<div class="tg-res-card-total">' +
                            '<span class="tg-res-card-total-label">Total paid</span>' +
                            '<span class="tg-res-card-total-amount">' + money(r.totalPrice) + '</span>' +
                        '</div>' +
                        '<div class="tg-res-card-actions">' +
                            '<button class="tg-res-btn tg-res-btn-review btn-review" data-code="' + escapeHtml(r.tripCode) + '" data-trip="' + escapeHtml(r.tripName) + '">' +
                                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>' +
                                'Review' +
                            '</button>' +
                            '<button class="tg-res-btn tg-res-btn-cancel btn-cancel" data-id="' + r._id + '">' +
                                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>' +
                                'Cancel' +
                            '</button>' +
                        '</div>' +
                    '</div>' +
                '</div>';

            listEl.appendChild(card);
            if (window.tgObserveFade) window.tgObserveFade(card);
        });

        wireCardActions();
    }

    /* ── Filtering + search ───────────────────────────────────── */
    var activeFilter = 'all';
    var searchTerm = '';

    function getFiltered() {
        return data.filter(function(r) {
            var d = daysFromNow(r.start);
            var isPast = d !== null && d < 0;
            if (activeFilter === 'upcoming' && isPast) return false;
            if (activeFilter === 'past' && !isPast) return false;
            if (searchTerm) {
                var hay = ((r.tripName || '') + ' ' + (r.resort || '') + ' ' + (r.tripCode || '')).toLowerCase();
                if (hay.indexOf(searchTerm) === -1) return false;
            }
            return true;
        });
    }

    function refreshList() {
        renderCards(getFiltered());
    }

    document.querySelectorAll('.tg-res-tab').forEach(function(t) {
        t.addEventListener('click', function() {
            document.querySelectorAll('.tg-res-tab').forEach(function(b) {
                b.classList.remove('is-active');
                b.setAttribute('aria-selected', 'false');
            });
            t.classList.add('is-active');
            t.setAttribute('aria-selected', 'true');
            activeFilter = t.getAttribute('data-filter');
            refreshList();
        });
    });

    document.getElementById('res-search').addEventListener('input', function(e) {
        searchTerm = e.target.value.trim().toLowerCase();
        refreshList();
    });

    /* ── KPI + tab counts ─────────────────────────────────────── */
    function updateKpis(rows) {
        document.getElementById('kpi-total').textContent = rows.length;
        var upcoming = rows.filter(function(r) {
            var d = daysFromNow(r.start); return d === null || d >= 0;
        }).length;
        document.getElementById('kpi-upcoming').textContent = upcoming;
        var travelers = rows.reduce(function(s, r) { return s + (parseInt(r.people, 10) || 1); }, 0);
        document.getElementById('kpi-travelers').textContent = travelers;
        var total = rows.reduce(function(s, r) { return s + (parseFloat(r.totalPrice) || 0); }, 0);
        document.getElementById('kpi-total-spent').textContent = '$' + total.toLocaleString('en-US', { maximumFractionDigits: 0 });
    }
    function updateTabCounts(rows) {
        var all = rows.length;
        var up = rows.filter(function(r) { var d = daysFromNow(r.start); return d === null || d >= 0; }).length;
        var past = rows.filter(function(r) { var d = daysFromNow(r.start); return d !== null && d < 0; }).length;
        document.getElementById('count-all').textContent = all;
        document.getElementById('count-upcoming').textContent = up;
        document.getElementById('count-past').textContent = past;
    }

    updateKpis(data);
    updateTabCounts(data);
    refreshList();

    /* ── Cancel / review wiring (delegated) ───────────────────── */
    function wireCardActions() {
        listEl.querySelectorAll('.btn-cancel').forEach(function(btn) {
            btn.onclick = async function() {
                var id = btn.getAttribute('data-id');
                if (!confirm('Cancel this reservation? This cannot be undone.')) return;
                btn.disabled = true;
                btn.innerHTML = 'Cancelling…';
                try {
                    var delRes = await fetch('/api/reservations/' + id, {
                        method: 'DELETE',
                        headers: { 'Authorization': 'Bearer ' + token }
                    });
                    if (delRes.ok) {
                        data = data.filter(function(r) { return r._id !== id; });
                        updateKpis(data);
                        updateTabCounts(data);
                        refreshList();
                        var msg = document.getElementById('cancel-message');
                        msg.textContent = '✓ Reservation cancelled successfully.';
                        msg.style.display = 'block';
                        setTimeout(function() { msg.style.display = 'none'; }, 4000);
                        if (!data.length) emptyEl.style.display = 'flex';
                    } else {
                        var d = await delRes.json();
                        if (window.tgToast) window.tgToast(d.message || 'Could not cancel reservation.', 'danger');
                        else alert(d.message || 'Could not cancel reservation.');
                    }
                } catch (err) {
                    if (window.tgToast) window.tgToast('Unable to connect. Please try again.', 'danger');
                } finally {
                    btn.disabled = false;
                }
            };
        });
    }

    document.getElementById('logout-btn').addEventListener('click', function() {
        localStorage.removeItem('travlr-token');
        window.location.href = '/login';
    });

    /* ── Review modal ─────────────────────────────────────────── */
    var modal      = document.getElementById('review-modal');
    var stars      = document.querySelectorAll('.rev-star');
    var ratingVal  = 0;
    var activeCode = null;
    var commentEl  = document.getElementById('review-comment');
    var countEl    = document.getElementById('review-count');
    var errEl      = document.getElementById('review-error');

    function paintStars(v) {
        stars.forEach(function(s) {
            s.classList.toggle('is-lit', parseInt(s.getAttribute('data-v'), 10) <= v);
        });
    }
    stars.forEach(function(s) {
        s.addEventListener('mouseenter', function() { paintStars(parseInt(s.getAttribute('data-v'), 10)); });
        s.addEventListener('click', function() {
            ratingVal = parseInt(s.getAttribute('data-v'), 10);
            paintStars(ratingVal);
        });
    });
    document.getElementById('review-stars').addEventListener('mouseleave', function() { paintStars(ratingVal); });
    commentEl.addEventListener('input', function() { countEl.textContent = commentEl.value.length; });

    var lastFocused = null;
    function trapFocus(e) {
        if (!modal.classList.contains('is-open')) return;
        if (e.key === 'Escape') { closeModal(); return; }
        if (e.key !== 'Tab') return;
        var focusable = modal.querySelectorAll('button, textarea, [href], [tabindex]:not([tabindex="-1"])');
        if (!focusable.length) return;
        var first = focusable[0]; var last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    }

    function openModal(code, name) {
        activeCode = code;
        document.getElementById('review-trip-name').textContent = name;
        ratingVal = 0; paintStars(0);
        commentEl.value = ''; countEl.textContent = '0';
        errEl.style.display = 'none';
        lastFocused = document.activeElement;
        modal.classList.add('is-open');
        document.body.style.overflow = 'hidden';
        document.addEventListener('keydown', trapFocus);
        setTimeout(function() {
            var firstStar = modal.querySelector('.rev-star');
            if (firstStar) firstStar.focus();
        }, 30);
    }
    function closeModal() {
        modal.classList.remove('is-open');
        document.body.style.overflow = '';
        document.removeEventListener('keydown', trapFocus);
        if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    document.body.addEventListener('click', function(e) {
        var btn = e.target.closest('.btn-review');
        if (btn) openModal(btn.getAttribute('data-code'), btn.getAttribute('data-trip'));
    });
    document.getElementById('review-close').addEventListener('click', closeModal);
    document.getElementById('review-cancel').addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });

    document.getElementById('review-submit').addEventListener('click', async function() {
        errEl.style.display = 'none';
        if (ratingVal < 1) { errEl.textContent = 'Please pick a star rating.'; errEl.style.display = 'block'; return; }
        if (commentEl.value.trim().length < 4) { errEl.textContent = 'Please write a few words about your trip.'; errEl.style.display = 'block'; return; }

        var btn = this; btn.disabled = true; var orig = btn.textContent; btn.textContent = 'Submitting…';
        try {
            var r = await fetch('/api/trips/' + activeCode + '/reviews', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
                body: JSON.stringify({ rating: ratingVal, comment: commentEl.value.trim() })
            });
            var raw = await r.text();
            var d = {}; try { d = raw ? JSON.parse(raw) : {}; } catch (e) {}

            if (r.ok) {
                closeModal();
                var msg = document.getElementById('cancel-message');
                msg.textContent = '✓ Thanks! Your review has been posted.';
                msg.style.display = 'block';
                setTimeout(function() { msg.style.display = 'none'; }, 4500);
            } else {
                errEl.textContent = d.message || ('Could not save your review (HTTP ' + r.status + ').');
                errEl.style.display = 'block';
            }
        } catch (err) {
            errEl.textContent = 'Network error: ' + err.message;
            errEl.style.display = 'block';
        } finally {
            btn.disabled = false; btn.textContent = orig;
        }
    });
})();
</script>

